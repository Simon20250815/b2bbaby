---
import { getSiteConfig } from '@/lib/site-config';

const config = getSiteConfig();
const currentPath = Astro.url.pathname;
---

<header class="bg-white/95 backdrop-blur-md border-b border-gray-200 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-blue-700 rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <span class="text-white font-bold text-sm">B2B</span>
        </div>
        <span class="text-xl font-bold text-gray-900 tracking-tight">baby</span>
      </a>

      <div class="hidden lg:flex items-center gap-8">
        {[
          { name: 'Products', href: '/products' },
          { name: 'OEM/ODM', href: '/oem-odm' },
          { name: 'Shipping Proof', href: '/shipping-proof', highlight: true },
          { name: 'Blog', href: '/blog' },
          { name: 'FAQ', href: '/faq' },
          { name: 'About', href: '/about' }
        ].map((item) => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <a
              key={item.name}
              href={item.href}
              class={`text-sm font-medium transition-colors relative ${
                isActive 
                  ? 'text-blue-600' 
                  : 'text-gray-600 hover:text-gray-900'
              }`}
            >
              {item.name}
              {isActive && (
                <span class={`absolute -bottom-1 left-0 w-full h-0.5 rounded-full ${
                  item.highlight ? 'bg-green-500' : 'bg-blue-500'
                }`}></span>
              )}
            </a>
          );
        })}
      </div>

      <div class="flex items-center gap-4">
        {config.social.linkedin && (
            <a
              href={config.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden md:flex p-2 text-gray-400 hover:text-blue-600 hover:bg-gray-100 rounded-lg transition-colors"
              aria-label="LinkedIn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7 0h3.8v2h.06c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.77 2.65 4.77 6.1V24h-4v-6.2c0-1.48-.03-3.38-2.06-3.38-2.06 0-2.38 1.6-2.38 3.28V24h-4V8z"/>
              </svg>
            </a>
          )}
          
          {config.company.whatsapp && (
            <a
              href={`https://wa.me/${config.company.whatsapp.replace(/\s/g, '')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden md:flex items-center gap-2 text-green-600 hover:text-green-700 font-medium text-sm"
              aria-label="WhatsApp"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span>WhatsApp</span>
            </a>
          )}
          
          {config.social.made_in_china && (
            <a
              href={config.social.made_in_china}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden md:flex items-center gap-2 text-orange-600 hover:text-orange-700 font-medium text-sm"
              aria-label="Made in China"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
              </svg>
              <span>MIC</span>
            </a>
          )}
        
        <a
          href="/contact"
          class={`inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm transition-colors shadow-sm hover:shadow-md ${
            currentPath === '/contact' 
              ? 'bg-blue-700 text-white' 
              : 'bg-blue-600 text-white hover:bg-blue-700'
          }`}
        >
          Get Free Quote
        </a>
      </div>
    </div>

    <div class="lg:hidden py-4 border-t border-gray-100">
      <div class="flex flex-wrap gap-2">
        {[
          { name: 'Products', href: '/products' },
          { name: 'OEM/ODM', href: '/oem-odm' },
          { name: 'Shipping Proof', href: '/shipping-proof', highlight: true },
          { name: 'Blog', href: '/blog' },
          { name: 'FAQ', href: '/faq' },
          { name: 'About', href: '/about' }
        ].map((item) => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <a
              key={item.name}
              href={item.href}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-colors ${
                isActive 
                  ? item.highlight 
                    ? 'bg-green-50 text-blue-600' 
                    : 'bg-blue-50 text-blue-600'
                  : 'bg-gray-50 text-gray-600 hover:bg-gray-100'
              }`}
            >
              {item.name}
            </a>
          );
        })}
      </div>
    </div>
  </nav>
</header>