<footer class="bg-gray-900 text-white">
  <div class="container mx-auto px-4 md:px-6">
    <div class="py-12 md:py-16">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
        <div>
          <a href="/" class="flex items-center gap-1 mb-4">
            <div class="bg-blue-600 text-white px-1.5 py-0.75 rounded-xl font-bold text-lg">
              B2B
            </div>
            <span class="text-xl font-bold text-white">baby</span>
