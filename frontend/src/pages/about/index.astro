---
import Layout from '@/layouts/Layout.astro';
import { generateOrganizationSchema, generateLocalBusinessSchema } from '@/lib/schema';

const organizationSchema = generateOrganizationSchema();
const localBusinessSchema = generateLocalBusinessSchema();
---

<Layout title="About Us - B2Bbaby | Professional Baby Product Manufacturer" description="Professional baby products manufacturer and sourcing expert from China, established in 2019, serving 30+ countries worldwide.">
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  
  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-10 md:py-16">
    <div class="container mx-auto px-4 md:px-6">
      <div class="text-center">
        <span class="inline-block bg-white/80 backdrop-blur-sm px-4 py-1 rounded-full text-sm font-medium text-blue-700 mb-4">
          About Us
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4">About B2Bbaby</h1>
        <p class="text-base md:text-lg text-neutral-600 max-w-3xl mx-auto">
          Your trusted partner for tested baby products from China. Established in 2019, serving brands worldwide.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-5xl mx-auto">
        <article class="mb-16">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Our Story</h2>
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <p class="text-neutral-600 text-sm md:text-base leading-relaxed">
                Founded in 2010 with a mission to provide high-quality, safe baby products to the global market, 
                we have grown into a trusted manufacturer and sourcing partner for brands worldwide.
              </p>
              <p class="text-neutral-600 text-sm md:text-base leading-relaxed">
                With <strong>15+ years of experience</strong> in the baby products industry, we understand the importance of 
                safety, quality, and reliability. Every product we produce goes through rigorous quality 
                control and meets international safety standards.
              </p>
              <div class="grid grid-cols-3 gap-4 mt-6">
                <div class="text-center p-4 bg-blue-50 rounded-xl">
                  <div class="text-2xl md:text-3xl font-bold text-blue-600">200+</div>
                  <div class="text-xs md:text-sm text-neutral-600 mt-1">Staff</div>
                </div>
                <div class="text-center p-4 bg-blue-50 rounded-xl">
                  <div class="text-2xl md:text-3xl font-bold text-blue-600">10,000</div>
                  <div class="text-xs md:text-sm text-neutral-600 mt-1">sqm Factory</div>
                </div>
                <div class="text-center p-4 bg-blue-50 rounded-xl">
                  <div class="text-2xl md:text-3xl font-bold text-blue-600">30+</div>
                  <div class="text-xs md:text-sm text-neutral-600 mt-1">Countries Served</div>
                </div>
              </div>
            </div>
            <div class="h-64 md:h-80 rounded-2xl overflow-hidden shadow-lg">
              <img 
                src="/images/pages/about/showroom.jpg"
                alt="B2Bbaby product showroom"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </article>

        <article class="mb-16">
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-6 md:p-8 border border-blue-100">
            <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Our Core Values</h2>
            <div class="grid md:grid-cols-3 gap-6">
              {[
                {
                  icon: 'shield',
                  title: 'Safety First',
                  desc: 'Products meet and exceed international safety standards including ASTM, EN, and CPC requirements',
                  color: 'blue'
                },
                {
                  icon: 'check-circle',
                  title: 'Quality Commitment',
                  desc: 'Rigorous QC at every stage of production - from raw materials to final packaging',
                  color: 'green'
                },
                {
                  icon: 'users',
                  title: 'Partner Success',
                  desc: 'Your success is our priority - we work closely with you to ensure market success',
                  color: 'purple'
                }
              ].map((item) => (
                <div key={item.title} class="text-center p-6 bg-white rounded-xl shadow-sm">
                  <div className={`w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4 ${
                    item.color === 'blue' ? 'bg-blue-100 text-blue-600' :
                    item.color === 'green' ? 'bg-green-100 text-green-600' :
                    'bg-purple-100 text-purple-600'
                  }`}>
                    {item.icon === 'shield' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                      </svg>
                    )}
                    {item.icon === 'check-circle' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    )}
                    {item.icon === 'users' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                    )}
                  </div>
                  <h3 class="font-semibold text-lg mb-2">{item.title}</h3>
                  <p class="text-sm text-neutral-600">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </article>

        <article class="mb-16">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Export Markets Served</h2>
          <p class="text-neutral-600 text-sm md:text-base mb-6">We proudly serve brands across the globe with proven track record:</p>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
            {[
              { region: 'North America', countries: ['United States', 'Canada', 'Mexico'], color: 'blue' },
              { region: 'Western Europe', countries: ['Germany', 'United Kingdom', 'France, Netherlands'], color: 'green' },
              { region: 'Oceania', countries: ['Australia', 'New Zealand'], color: 'purple' },
              { region: 'Asia-Pacific', countries: ['Japan', 'South Korea', 'Singapore'], color: 'orange' }
            ].map((item) => (
              <div key={item.region} className={`p-6 rounded-2xl border ${
                item.color === 'blue' ? 'bg-blue-50 border-blue-200' :
                item.color === 'green' ? 'bg-green-50 border-green-200' :
                item.color === 'purple' ? 'bg-purple-50 border-purple-200' :
                'bg-orange-50 border-orange-200'
              }`}>
                <h3 className={`font-bold mb-3 ${
                  item.color === 'blue' ? 'text-blue-800' :
                  item.color === 'green' ? 'text-green-800' :
                  item.color === 'purple' ? 'text-purple-800' :
                  'text-orange-800'
                }`}>{item.region}</h3>
                <ul className="text-sm text-neutral-600 space-y-2">
                  {item.countries.map(country => (
                    <li key={country} className="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" className="text-green-500">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {country}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </article>

        <article class="mb-16">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Certifications & Audit Reports</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {[
              { name: 'ISO 9001:2015', cert: 'Quality Management System', valid: 'Valid Certificate', image: '/images/pages/about/证书/iso9001-certificate.jpg' },
              { name: 'CE Marking', cert: 'EN 71 Certified', valid: 'European Standards', image: '/images/pages/about/证书/en-certificate.jpg' },
              { name: 'CPC', cert: 'Children\'s Product Certificate', valid: 'ASTM F963 Compliant', image: '/images/pages/about/证书/cpc-certificate.jpg' },
              { name: 'ASTM F963', cert: 'US Safety Standard', valid: 'GZHL2309033714IP', image: '/images/pages/about/证书/astm-certificate.jpg' },
              { name: 'RoHS Test', cert: 'RoHS, Halogen, Formaldehyde', valid: 'TLTBABY-30X 5.0mm', image: '/images/pages/about/证书/rohs-test-report.jpg' },
              { name: 'Business License', cert: 'Business Registration', valid: 'No. 91241830137', image: '/images/pages/about/证书/business-license.jpg' },
              { name: 'Stroller Test', cert: 'Baby Stroller Report', valid: 'Foldable Stroller', image: '/images/pages/about/证书/stroller-test-report.jpg' },
              { name: 'Bed Rail Test', cert: 'EU Standard Report', valid: 'Safety Bed Rail', image: '/images/pages/about/证书/bed-rail-test-report.jpg' },
              { name: 'Test Report 2025', cert: 'Product Testing', valid: 'Batch SHHL2509', image: '/images/pages/about/证书/test-report-2025.jpg' },
              { name: 'Test Report 2026', cert: 'Product Testing', valid: 'Batch SHHL2605', image: '/images/pages/about/证书/test-report-2026.jpg' }
            ].map((item, idx) => (
              <div key={idx} class="bg-white rounded-2xl overflow-hidden shadow-sm border border-neutral-200 hover:shadow-md transition-shadow group cursor-pointer">
                <div class="h-48 md:h-56 bg-neutral-100 flex items-center justify-center p-2">
                  <img 
                    src={item.image}
                    alt={item.name}
                    class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-4">
                  <h3 class="font-bold text-lg text-neutral-900 mb-1">{item.name}</h3>
                  <p class="text-sm text-neutral-600">{item.cert}</p>
                  <p class="text-xs text-neutral-500">{item.valid}</p>
                </div>
              </div>
            ))}
          </div>
          <p class="text-center mt-6 text-sm text-neutral-500">
            Full certification documents available upon request
          </p>
        </article>

        <article class="mb-16">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Our Facility</h2>
          <div class="grid md:grid-cols-3 gap-4">
            {[
              { alt: 'Production floor - Baby stroller assembly line', image: '/images/pages/about/factory/factory-1.jpg' },
              { alt: 'Quality control laboratory', image: '/images/pages/about/factory/factory-2.jpg' },
              { alt: 'Warehouse and shipping facility', image: '/images/pages/about/exhibition/exhibition-products.jpg' }
            ].map((item, idx) => (
              <div key={idx} class="h-48 md:h-56 rounded-2xl overflow-hidden shadow-lg group">
                <img 
                  src={item.image}
                  alt={item.alt}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </article>

        <article class="mb-16">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Trade Shows & Exhibitions</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
            {[
              { alt: 'Exhibition Booth Display', image: '/images/pages/about/exhibition/exhibition-booth.jpg' },
              { alt: 'Canton Fair Exhibition', image: '/images/pages/about/exhibition/exhibition-canton-fair.jpg' },
              { alt: 'Product Display', image: '/images/pages/about/exhibition/exhibition-display.jpg' },
              { alt: 'Business Meeting at Exhibition', image: '/images/pages/about/exhibition/exhibition-meeting.jpg' },
              { alt: 'Product Showcase', image: '/images/pages/about/exhibition/exhibition-products.jpg' },
              { alt: 'Exhibition Showcase', image: '/images/pages/about/exhibition/exhibition-showcase.jpg' },
              { alt: 'Team at Exhibition', image: '/images/pages/about/exhibition/exhibition-team.jpg' },
              { alt: 'Visitors at Exhibition', image: '/images/pages/about/exhibition/exhibition-visitors.jpg' }
            ].map((item, idx) => (
              <div key={idx} class="h-40 md:h-48 rounded-2xl overflow-hidden shadow-lg group">
                <img 
                  src={item.image}
                  alt={item.alt}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
          <p class="text-center mt-4 text-neutral-500 text-sm">
            We participate in major trade shows including Canton Fair, HK Baby Products Fair, and ABC Kids Expo
          </p>
        </article>

        <div class="text-center">
          <a href="/contact" class="inline-flex items-center gap-2 bg-gradient-primary text-white px-8 py-4 rounded-xl font-semibold hover:opacity-90 transition-all">
            Partner With Us
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>