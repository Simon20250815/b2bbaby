---
import Layout from '@/layouts/Layout.astro';
import { generateServiceSchema } from '@/lib/schema';

const quoteSchema = generateServiceSchema('quote');
---

<Layout title="Get a Quote - B2Bbaby | Request Product Pricing" description="Request a detailed quote for baby strollers, safety gates, and high chairs. Fast response within 24 hours with complete pricing, MOQ, and delivery information.">
  <script type="application/ld+json" set:html={JSON.stringify(quoteSchema)} />

  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-10 md:py-16">
    <div class="container mx-auto px-4 md:px-6">
      <div class="text-center">
        <span class="inline-block bg-white/80 backdrop-blur-sm px-4 py-1 rounded-full text-sm font-medium text-blue-700 mb-4">
          Quote Request
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4">Get a Free Quote</h1>
        <p class="text-base md:text-lg text-neutral-600 max-w-2xl mx-auto">
          Request a detailed quotation for your baby product order. We typically respond within 24 hours.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8 mb-10">
          <div class="bg-blue-50 rounded-xl p-6 text-center">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-neutral-900 mb-2">24h Response</h3>
            <p class="text-sm text-neutral-600">We respond to all quote requests within 24 hours</p>
          </div>
          <div class="bg-green-50 rounded-xl p-6 text-center">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-bold text-neutral-900 mb-2">Zero Obligation</h3>
            <p class="text-sm text-neutral-600">Get pricing information with no commitment required</p>
          </div>
          <div class="bg-purple-50 rounded-xl p-6 text-center">
            <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="font-bold text-neutral-900 mb-2">Detailed Quotes</h3>
            <p class="text-sm text-neutral-600">Includes pricing, lead time, certifications, and more</p>
          </div>
        </div>

        <form id="quote-form" class="space-y-6">
          <div class="bg-neutral-50 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-neutral-900 mb-6">Company Information</h2>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-neutral-700 mb-2">
                  Your Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="Enter your full name"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-neutral-700 mb-2">
                  Company Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  required
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="Enter your company name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">
                  Email Address <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="Enter your business email"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-neutral-700 mb-2">
                  Phone / WhatsApp
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="+1 234 567 8900"
                />
              </div>
            </div>
          </div>

          <div class="bg-neutral-50 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-neutral-900 mb-6">Product Requirements</h2>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="productType" class="block text-sm font-medium text-neutral-700 mb-2">
                  Product Type <span class="text-red-500">*</span>
                </label>
                <select
                  id="productType"
                  name="productType"
                  required
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                >
                  <option value="">Select a product</option>
                  <option value="baby-stroller">Baby Stroller</option>
                  <option value="safety-gate">Safety Gate</option>
                  <option value="high-chair">High Chair</option>
                  <option value="bed-rail">Baby Bed Rail</option>
                  <option value="multiple">Multiple Products</option>
                  <option value="oem">OEM/ODM Custom</option>
                </select>
              </div>
              <div>
                <label for="quantity" class="block text-sm font-medium text-neutral-700 mb-2">
                  Quantity <span class="text-red-500">*</span>
                </label>
                <input
                  type="number"
                  id="quantity"
                  name="quantity"
                  required
                  min="1"
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="Enter quantity needed"
                />
              </div>
              <div>
                <label for="targetMarket" class="block text-sm font-medium text-neutral-700 mb-2">
                  Target Market
                </label>
                <select
                  id="targetMarket"
                  name="targetMarket"
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                >
                  <option value="">Select market</option>
                  <option value="usa">United States</option>
                  <option value="eu">European Union</option>
                  <option value="uk">United Kingdom</option>
                  <option value="canada">Canada</option>
                  <option value="australia">Australia</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="certification" class="block text-sm font-medium text-neutral-700 mb-2">
                  Required Certification
                </label>
                <select
                  id="certification"
                  name="certification"
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                >
                  <option value="">Select certification</option>
                  <option value="astm">ASTM (US Standard)</option>
                  <option value="en">EN (EU Standard)</option>
                  <option value="cpc">CPC (US Certificate)</option>
                  <option value="ce">CE Marking</option>
                  <option value="iso">ISO 9001</option>
                  <option value="multiple">Multiple Certifications</option>
                  <option value="none">Not Sure</option>
                </select>
              </div>
            </div>
          </div>

          <div class="bg-neutral-50 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-neutral-900 mb-6">Customization & Other Details</h2>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="customization" class="block text-sm font-medium text-neutral-700 mb-2">
                  Customization Needs
                </label>
                <select
                  id="customization"
                  name="customization"
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                >
                  <option value="">Select option</option>
                  <option value="none">No Customization</option>
                  <option value="logo">Logo/Brand Customization</option>
                  <option value="color">Color Customization</option>
                  <option value="packaging">Packaging Customization</option>
                  <option value="full-oem">Full OEM Service</option>
                  <option value="odm">ODM/Design Service</option>
                </select>
              </div>
              <div>
                <label for="leadTime" class="block text-sm font-medium text-neutral-700 mb-2">
                  Required Delivery Date
                </label>
                <input
                  type="text"
                  id="leadTime"
                  name="leadTime"
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="e.g., Within 2 months"
                />
              </div>
              <div class="md:col-span-2">
                <label for="message" class="block text-sm font-medium text-neutral-700 mb-2">
                  Additional Requirements
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows={4}
                  class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none"
                  placeholder="Please describe any additional requirements, such as specific colors, materials, packaging preferences, or questions about our products..."
                />
              </div>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 bg-neutral-50 rounded-xl">
            <input
              type="checkbox"
              id="privacy"
              name="privacy"
              required
              class="mt-1 h-4 w-4 text-blue-600 border-neutral-300 rounded focus:ring-blue-500"
            />
            <label for="privacy" class="text-sm text-neutral-600">
              I agree to the <a href="/privacy" class="text-blue-600 hover:underline">Privacy Policy</a> and consent to having B2Bbaby store and process my information for quote purposes.
            </label>
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white py-4 rounded-xl font-semibold hover:from-blue-700 hover:to-blue-800 transition-all hover:shadow-lg"
          >
            Submit Quote Request
          </button>
        </form>

        <div id="form-success" class="hidden mt-6 p-6 bg-green-50 border border-green-200 rounded-xl text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-green-800 mb-2">Quote Request Submitted!</h3>
          <p class="text-green-700">
            Thank you for your inquiry. Our sales team will review your requirements and respond within 24 hours.
          </p>
          <p class="text-sm text-green-600 mt-4">
            You can also contact us directly via WhatsApp at +86 176 8112 8186 for urgent inquiries.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-neutral-50">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-neutral-900 mb-4">Need Immediate Assistance?</h2>
        <p class="text-neutral-600 mb-6">
          For urgent inquiries or complex requirements, feel free to contact us directly.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="mailto:info@b2bbaby.com" class="inline-flex items-center justify-center px-6 py-3 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Email Us
          </a>
          <a href="https://wa.me/8617681128186" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 bg-green-600 text-white rounded-xl font-semibold hover:bg-green-700 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21" />
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    function getUTMParams() {
      const urlParams = new URLSearchParams(window.location.search);
      return {
        utm_source: urlParams.get('utm_source') || '',
        utm_medium: urlParams.get('utm_medium') || '',
        utm_campaign: urlParams.get('utm_campaign') || '',
        utm_term: urlParams.get('utm_term') || '',
        utm_content: urlParams.get('utm_content') || '',
        referrer: document.referrer || '',
        landing_page: window.location.pathname
      };
    }

    document.getElementById('quote-form').addEventListener('submit', async function(e) {
      e.preventDefault();

      const button = this.querySelector('button[type="submit"]');
      const originalText = button.textContent;
      button.textContent = 'Submitting...';
      button.disabled = true;

      try {
        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        const utmParams = getUTMParams();
        const payload = { ...data, ...utmParams, type: 'quote', form_type: 'quote' };

        const apiUrl = '/api/send-email.json';

        const response = await fetch(apiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          const result = await response.json();

          if (result.success) {
            this.reset();
            document.getElementById('form-success').classList.remove('hidden');
            document.getElementById('form-success').scrollIntoView({ behavior: 'smooth' });
          } else {
            alert('Failed to submit quote request. Please try again later.');
          }
        } else {
          alert('API endpoint not found. Please check server configuration.');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Failed to submit quote request. Please try again later.');
      } finally {
        button.textContent = originalText;
        button.disabled = false;
      }
    });
  </script>
</Layout>
