---
import Layout from '@/layouts/Layout.astro';
import { generateArticleSchema } from '@/lib/schema';

const pageTitle = 'Baby Bed Rail Factory: ASTM EN Certified Wholesale & OEM';
const pageDescription = 'Professional baby bed rail manufacturer. ASTM, EN, CE certified. Child safety gates, bed rails, stair gates. Wholesale pricing & OEM customization.';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    generateArticleSchema(pageTitle, pageDescription),
    {
      "@type": "ProductGroup",
      "name": "Baby Bed Rails & Safety Gates",
      "description": "ASTM and EN certified bed rails and safety gates for wholesale and OEM",
      "productGroupID": "bed-rails-safety-gates"
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  
  <section class="bg-gradient-to-r from-emerald-600 to-teal-700 text-white py-12 md:py-20">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl">
        <span class="inline-block bg-white/20 text-white px-4 py-1 rounded-full text-sm font-medium mb-6">Child Safety First</span>
        <h1 class="text-3xl md:text-5xl font-bold mb-6 leading-tight">Baby Bed Rail Factory</h1>
        <p class="text-lg md:text-xl text-white/90 mb-8">ASTM & EN Certified | Bed Rails & Safety Gates | Wholesale & OEM | 15+ Years Experience</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/quote" class="inline-flex items-center justify-center gap-2 bg-white text-emerald-700 px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition-all hover:shadow-xl">
            Get a Quote
          </a>
          <a href="/products" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/10 transition-all">
            View All Products
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-4xl font-bold text-neutral-900 mb-4">Our Safety Product Range</h2>
        <p class="text-base md:text-lg text-neutral-600 max-w-3xl mx-auto">Comprehensive child safety solutions for bedrooms and stairways</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            title: "Bed Rails for Toddlers",
            desc: "Adjustable bed rails in various sizes, easy to install, safe for all bed types",
            certs: ["ASTM F2085", "EN 12227"],
            moq: "300 units",
            sizes: ["120cm", "150cm", "180cm"]
          },
          {
            title: "Stair Safety Gates",
            desc: "Pressure-mounted and hardware-mounted gates for stairs and doorways",
            certs: ["ASTM F1004", "EN 1930"],
            moq: "400 units",
            types: ["Auto-close", "Walk-through"]
          },
          {
            title: "Fireplace Guards",
            desc: "Heat-resistant guards to protect children from fireplaces and heaters",
            certs: ["EN 1930"],
            moq: "200 units",
            materials: ["Steel", "Mesh"]
          }
        ].map((item, idx) => (
          <div key={idx} class="bg-neutral-50 rounded-2xl p-8 hover:shadow-lg transition-all border border-neutral-200">
            <div class="w-14 h-14 bg-emerald-100 rounded-xl flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-600">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <line x1="9" y1="9" x2="15" y2="9"/>
                <line x1="9" y1="15" x2="15" y2="15"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-neutral-900 mb-3">{item.title}</h3>
            <p class="text-neutral-600 mb-6">{item.desc}</p>
            <div class="space-y-3">
              <div>
                <span class="text-sm text-neutral-500">Certifications:</span>
                <div class="flex flex-wrap gap-2 mt-1">
                  {item.certs.map((cert, i) => (
                    <span key={i} class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full text-xs font-medium">{cert}</span>
                  ))}
                </div>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <span class="text-neutral-500">MOQ:</span>
                <span class="font-medium text-neutral-900">{item.moq}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-neutral-50">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl md:text-4xl font-bold text-neutral-900 mb-6">Why Choose Our Safety Gates?</h2>
          <div class="space-y-4">
            {[
              "100% compliance with ASTM and EN safety standards",
              "Rigorous testing for strength and durability",
              "Non-toxic, child-safe materials only",
              "Easy installation with clear instructions",
              "Custom colors and branding available"
            ].map((point, idx) => (
              <div key={idx} class="flex items-start gap-3">
                <div class="flex-shrink-0 w-6 h-6 bg-emerald-600 rounded-full flex items-center justify-center mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <span class="text-neutral-700">{point}</span>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-xl font-bold text-neutral-900 mb-4">Quality Assurance</h3>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-neutral-200">
            <div class="space-y-4">
              <div class="flex justify-between items-center pb-4 border-b border-neutral-200">
                <span class="text-neutral-600">Safety Testing</span>
                <span class="text-emerald-600 font-bold">100% Pass</span>
              </div>
              <div class="flex justify-between items-center pb-4 border-b border-neutral-200">
                <span class="text-neutral-600">Lead & Phthalate Free</span>
                <span class="text-emerald-600 font-bold">Yes</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-neutral-600">Warranty</span>
                <span class="text-emerald-600 font-bold">12 Months</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-gradient-to-r from-emerald-600 to-teal-700 text-white">
    <div class="container mx-auto px-4 md:px-6 text-center">
      <h2 class="text-2xl md:text-4xl font-bold mb-4">Need Child Safety Products?</h2>
      <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">Get certified bed rails and safety gates with competitive wholesale pricing.</p>
      <a href="/quote" class="inline-flex items-center justify-center gap-2 bg-white text-emerald-700 px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition-all hover:shadow-xl">
        Request Quote Now
      </a>
    </div>
  </section>
</Layout>
