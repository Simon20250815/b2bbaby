---
import Layout from '@/layouts/Layout.astro';
import { blogPosts } from '@/lib/blog-data';

const topics = [
  {
    id: 'compliance',
    name: 'Compliance & Certification',
    description: 'Understand certification requirements for different markets including US, EU, UK, and more.',
    icon: 'shield',
    color: 'blue'
  },
  {
    id: 'buying-guide',
    name: 'Buying Guide',
    description: 'Step-by-step guides for sourcing baby products from China.',
    icon: 'book',
    color: 'green'
  },
  {
    id: 'oem-odm',
    name: 'OEM/ODM Manufacturing',
    description: 'Learn about custom manufacturing, private label, and OEM services.',
    icon: 'factory',
    color: 'purple'
  },
  {
    id: 'market-trends',
    name: 'Market Trends',
    description: 'Stay updated with the latest baby product market trends and insights.',
    icon: 'trending',
    color: 'orange'
  },
  {
    id: 'qc-shipping',
    name: 'QC & Shipping',
    description: 'Quality control procedures and international shipping guides.',
    icon: 'truck',
    color: 'red'
  }
];

const getPostsByTopic = (topicId: string) => {
  return blogPosts.filter(post => post.category === topicId);
};

const getTopicStats = (topicId: string) => {
  const posts = getPostsByTopic(topicId);
  return {
    count: posts.length,
    totalReadTime: posts.reduce((acc, post) => acc + parseInt(post.readTime), 0)
  };
};
---

<Layout title="Baby Product Sourcing Topics - B2Bbaby | Expert Guides" description="Explore comprehensive guides on baby product compliance, sourcing, OEM/ODM manufacturing, market trends, and quality control.">
  
  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-10 md:py-16">
    <div class="container mx-auto px-4 md:px-6">
      <div class="text-center">
        <span class="inline-block bg-white/80 backdrop-blur-sm px-4 py-1 rounded-full text-sm font-medium text-blue-700 mb-4">
          Expert Knowledge Base
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4">Baby Product Sourcing Topics</h1>
        <p class="text-base md:text-lg text-neutral-600 max-w-2xl mx-auto">
          Comprehensive guides and resources to help you source, certify, and ship baby products from China.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto mb-16">
        {topics.map((topic) => {
          const stats = getTopicStats(topic.id);
          const posts = getPostsByTopic(topic.id);
          
          return (
            <div class="bg-white border border-neutral-200 rounded-2xl overflow-hidden hover:shadow-xl transition-all hover:-translate-y-1">
              <div class={`bg-${topic.color}-50 p-6`}>
                <div class="flex items-center justify-between mb-3">
                  <div class={`w-12 h-12 bg-${topic.color}-100 rounded-xl flex items-center justify-center`}>
                    {topic.icon === 'shield' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class={`w-6 h-6 text-${topic.color}-600`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                      </svg>
                    )}
                    {topic.icon === 'book' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class={`w-6 h-6 text-${topic.color}-600`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                    )}
                    {topic.icon === 'factory' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class={`w-6 h-6 text-${topic.color}-600`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                      </svg>
                    )}
                    {topic.icon === 'trending' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class={`w-6 h-6 text-${topic.color}-600`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                      </svg>
                    )}
                    {topic.icon === 'truck' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class={`w-6 h-6 text-${topic.color}-600`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
                      </svg>
                    )}
                  </div>
                  <span class={`bg-${topic.color}-200 text-${topic.color}-800 text-xs px-3 py-1 rounded-full font-medium`}>
                    {stats.count} Articles
                  </span>
                </div>
                <h3 class="text-lg font-bold text-neutral-900 mb-2">{topic.name}</h3>
                <p class="text-sm text-neutral-600">{topic.description}</p>
              </div>
              
              <div class="p-6">
                {posts.length > 0 ? (
                  <div class="space-y-3">
                    {posts.map((post) => (
                      <a
                        key={post.id}
                        href={`/blog/${post.slug}`}
                        class="block group"
                      >
                        <div class="flex items-start gap-3 p-3 rounded-lg hover:bg-neutral-50 transition">
                          <img 
                            src={post.image} 
                            alt={post.title}
                            class="w-16 h-16 rounded-lg object-cover flex-shrink-0"
                            loading="lazy"
                          />
                          <div class="flex-1 min-w-0">
                            <h4 class="text-sm font-semibold text-neutral-900 group-hover:text-blue-600 transition line-clamp-2 mb-1">
                              {post.title}
                            </h4>
                            <span class="text-xs text-neutral-500">{post.readTime} read</span>
                          </div>
                        </div>
                      </a>
                    ))}
                  </div>
                ) : (
                  <p class="text-sm text-neutral-500 text-center py-4">Coming soon...</p>
                )}
                
                <div class="mt-4 pt-4 border-t border-neutral-100">
                  <a 
                    href={`#${topic.id}`}
                    class="text-sm text-blue-600 font-semibold hover:text-blue-700 flex items-center gap-2"
                  >
                    View all articles
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-8 md:p-10 text-center">
          <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-4">Need Expert Guidance?</h2>
          <p class="text-neutral-600 mb-6 max-w-2xl mx-auto">
            Get personalized consultation from our sourcing experts. We can help with certification requirements, supplier verification, and quality control for your baby product imports.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/contact" class="bg-blue-600 text-white px-8 py-4 rounded-xl font-semibold hover:bg-blue-700 transition">
              Get Free Consultation
            </a>
            <a href="/quote" class="bg-white text-blue-600 border-2 border-blue-600 px-8 py-4 rounded-xl font-semibold hover:bg-blue-50 transition">
              Request Quote
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-neutral-50">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-neutral-900 mb-6 text-center">Popular Resources</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <a href="/products" class="bg-white p-6 rounded-xl border border-neutral-200 hover:shadow-lg transition text-center">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <h3 class="font-bold text-neutral-900 mb-1">View Products</h3>
            <p class="text-sm text-neutral-600">Browse our certified baby products</p>
          </a>
          
          <a href="/oem-odm" class="bg-white p-6 rounded-xl border border-neutral-200 hover:shadow-lg transition text-center">
            <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
              </svg>
            </div>
            <h3 class="font-bold text-neutral-900 mb-1">OEM/ODM Service</h3>
            <p class="text-sm text-neutral-600">Custom manufacturing solutions</p>
          </a>
          
          <a href="/faq" class="bg-white p-6 rounded-xl border border-neutral-200 hover:shadow-lg transition text-center">
            <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-neutral-900 mb-1">FAQ Page</h3>
            <p class="text-sm text-neutral-600">Common questions answered</p>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
