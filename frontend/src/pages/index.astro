---
import Layout from '@/layouts/Layout.astro';
import { getProducts, getFAQs } from '@/lib/directus';
import { productsData } from '@/lib/product-data';
import { faqs as fallbackFaqs } from '@/lib/faq-data';

const directusProducts = await getProducts();
const products = directusProducts.length > 0 ? directusProducts : productsData;

const directusFaqs = await getFAQs();
const featuredFaqs = (directusFaqs.length > 0 ? directusFaqs : fallbackFaqs).slice(0, 3);
---

<Layout title="B2Bbaby - China Baby Product Manufacturer | ASTM/EN Certified Strollers, Safety Gates" description="Professional baby product manufacturer from China. ASTM/EN certified baby stroller, safety gate, high chair. MOQ 50+, 7-day samples, full QC support for US/EU brands.">
  <div class="font-sans">
    <!-- Hero Section -->
    <section class="relative min-h-screen bg-gradient-to-br from-white via-blue-50 to-indigo-50">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-20 right-10 w-72 h-72 bg-blue-200/30 rounded-full blur-3xl"></div>
        <div class="absolute bottom-20 left-10 w-96 h-96 bg-indigo-200/30 rounded-full blur-3xl"></div>
      </div>
      
      <div class="container mx-auto px-6 py-20 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center min-h-[80vh]">
          <div class="space-y-8">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-full text-sm font-semibold">
              <span class="w-2 h-2 bg-white/80 rounded-full animate-pulse"></span>
              Trusted by 200+ Global Brands
            </div>
            
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight">
              China's Leading
              <span class="block text-blue-600 mt-2">Wholesale Baby Strollers&Baby bed barrier for Retailers</span>
              <span class="block text-gray-600 font-normal text-2xl md:text-3xl lg:text-4xl mt-4">Manufacturer & Sourcing Partner</span>
            </h1>
            
            <p class="text-lg text-gray-600 leading-relaxed max-w-xl">
              ASTM/EN certified products with MOQ starting at 50 pieces. 7-day sample delivery, real-time QC tracking, and dedicated support for your baby product business.
            </p>
            
            <div class="flex flex-wrap gap-6">
              {[
                { label: 'Certifications', value: 'CE / CPC / ISO 9001' },
                { label: 'Export Batches', value: '127+ to US/EU' },
                { label: 'Lead Time', value: '7 Days Samples' }
              ].map((item, idx) => (
                <div key={idx} class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs text-gray-500">{item.label}</div>
                    <div class="text-sm font-semibold text-gray-900">{item.value}</div>
                  </div>
                </div>
              ))}
            </div>
            
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition-all hover:shadow-lg hover:-translate-y-0.5">
                Get Free Quote
              </a>
              <a href="/products" class="inline-flex items-center justify-center px-8 py-4 border-2 border-gray-300 text-gray-700 rounded-xl font-semibold hover:border-blue-600 hover:text-blue-600 transition-all">
                View Products
              </a>
            </div>
          </div>
          
          <div class="relative">
            <div class="grid grid-cols-2 gap-6">
              <div class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="aspect-square bg-gray-100">
                  <img 
                    src="/images/pages/home/stroller.jpg" 
                    alt="Baby stroller products"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-4 bg-gradient-to-t from-gray-50 to-white">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                      <span class="text-xl">📊</span>
                    </div>
                    <div>
                      <div class="text-lg font-bold text-gray-900">180,000+</div>
                      <div class="text-xs text-gray-500">Units Exported</div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="aspect-square bg-gray-100">
                  <img 
                    src="/images/pages/home/products.jpg" 
                    alt="Baby products collection"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-4 bg-gradient-to-t from-gray-50 to-white">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                      <span class="text-xl">🌍</span>
                    </div>
                    <div>
                      <div class="text-lg font-bold text-gray-900">30+</div>
                      <div class="text-xs text-gray-500">Countries Served</div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="aspect-square bg-gray-100">
                  <img 
                    src="/images/pages/home/bedrail.jpg" 
                    alt="Baby bed rail product"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-4 bg-gradient-to-t from-gray-50 to-white">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                      <span class="text-xl">✅</span>
                    </div>
                    <div>
                      <div class="text-lg font-bold text-gray-900">Zero</div>
                      <div class="text-xs text-gray-500">Product Recalls</div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="aspect-square bg-gray-100">
                  <img 
                    src="/images/pages/home/service.jpg" 
                    alt="Customer service team"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-4 bg-gradient-to-t from-gray-50 to-white">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
                      <span class="text-xl">⏱️</span>
                    </div>
                    <div>
                      <div class="text-lg font-bold text-gray-900">24h</div>
                      <div class="text-xs text-gray-500">Response</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-1.5 bg-green-100 text-green-700 rounded-full text-sm font-semibold mb-4">
            Why B2Bbaby
          </span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Why Buyers Choose Us</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            Trusted by 200+ brands worldwide for reliable baby product manufacturing
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {[
            {
              icon: '🏭',
              title: '10+ Years Experience',
              desc: 'Professional manufacturer since 2019 with proven track record'
            },
            {
              icon: '✅',
              title: 'Certified Quality',
              desc: 'ASTM, EN, CE, CPC, ISO 9001 certified products'
            },
            {
              icon: '📦',
              title: 'Flexible MOQ',
              desc: 'MOQ starting from 50 pieces for most products'
            },
            {
              icon: '🚀',
              title: 'Fast Samples',
              desc: 'Sample delivery in just 7-10 days'
            },
            {
              icon: '🔍',
              title: 'Full QC Support',
              desc: 'Three-stage quality inspection on every order'
            },
            {
              icon: '🎨',
              title: 'OEM/ODM Available',
              desc: 'Custom design, logo, and packaging services'
            },
            {
              icon: '🌍',
              title: '30+ Countries',
              desc: 'Products exported to US, EU, UK, Australia and more'
            },
            {
              icon: '💬',
              title: '24h Response',
              desc: 'Professional team ready to assist you'
            }
          ].map((item, idx) => (
            <div key={idx} class="bg-gray-50 rounded-2xl p-6 hover:shadow-lg transition-all">
              <div class="text-4xl mb-4">{item.icon}</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-sm text-gray-600">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 bg-white border-y border-gray-100">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: '200+', label: 'Global Clients' },
            { value: '50+', label: 'Product Categories' },
            { value: '127+', label: 'Export Batches' },
            { value: '99.8%', label: 'On-Time Delivery' }
          ].map((stat, idx) => (
            <div key={idx} class="text-center">
              <div class="text-3xl md:text-4xl font-bold text-blue-600 mb-2">{stat.value}</div>
              <div class="text-sm text-gray-500">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Products Section -->
    <section class="py-24 bg-gray-50">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 rounded-full text-sm font-semibold mb-4">
            Featured Products
          </span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Core Products</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            Premium baby products certified for international markets
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {products.map((product) => (
            <article key={product.id} class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <div class="relative aspect-[4/3] bg-gray-100 overflow-hidden">
                {product.image || product.image_url ? (
                  <img 
                    src={product.image || product.image_url} 
                    alt={product.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                  </div>
                )}
                <div class="absolute top-4 left-4">
                  <span class="bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-gray-800 shadow-sm">
                    MOQ: {product.moq} PCS
                  </span>
                </div>
              </div>
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {product.certifications?.slice(0, 2).map((cert, idx) => (
                    <span key={idx} class="text-xs font-medium px-2 py-0.5 bg-green-50 text-green-700 rounded">
                      {cert}
                    </span>
                  ))}
                </div>
                <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
                  {product.title}
                </h3>
                <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                  {product.description || product.description_en}
                </p>
                <a href={`/products/${product.slug}`} class="inline-flex items-center text-blue-600 font-semibold text-sm hover:text-blue-700 group">
                  View Details
                  <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
        
        <div class="text-center mt-12">
          <a href="/products" class="inline-flex items-center px-6 py-3 border-2 border-blue-600 text-blue-600 rounded-xl font-semibold hover:bg-blue-600 hover:text-white transition-all">
            View All Products
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-1.5 bg-indigo-100 text-indigo-700 rounded-full text-sm font-semibold mb-4">
            Services
          </span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">What We Offer</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            Comprehensive solutions for your baby product sourcing needs
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 gap-8">
          <div id="oem-card" class="bg-gradient-to-br from-orange-500 to-amber-600 rounded-2xl p-8 text-white relative overflow-hidden group hover:shadow-xl transition-all duration-300">
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                  </svg>
                </div>
                <h3 class="text-xl font-bold">OEM Service</h3>
              </div>
              <div class="mb-6">
                <div class="flex items-center gap-2 text-sm font-medium mb-2">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18 6l-2.92 6.56L10 12l5.08-4.56L6 18h12z"/>
                  </svg>
                  Private Label Manufacturing
                </div>
                <p class="text-orange-100 text-sm mt-2">
                  "Bring your brand to life with our certified production lines."
                </p>
              </div>
              <ul class="space-y-2 mb-6">
                {['Logo Embroidery', 'Custom Packaging', 'Material Selection', 'MOQ: 50 Units'].map((item) => (
                  <li key={item} class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-green-300" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a href="/oem-odm#oem" class="inline-flex items-center text-sm font-semibold border border-white/30 px-4 py-2 rounded-lg hover:bg-white/10 transition-colors group-hover:translate-x-1">
                Learn More
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
          
          <div id="odm-card" class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-8 text-white relative overflow-hidden group hover:shadow-xl transition-all duration-300">
            <div class="absolute bottom-0 left-0 w-32 h-32 bg-white/10 rounded-full translate-y-1/2 -translate-x-1/2"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                  </svg>
                </div>
                <h3 class="text-xl font-bold">ODM Service</h3>
              </div>
              <div class="mb-6">
                <div class="flex items-center gap-2 text-sm font-medium mb-2">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 8l5 5H7l5-5zm0-3.5c.83 0 1.5-.67 1.5-1.5S6.83 6 6 6 4.5 6.67 4.5 7.5 5.17 9 6 9z"/>
                  </svg>
                  Custom Design & Development
                </div>
                <p class="text-blue-100 text-sm mt-2">
                  "No design? No problem. We offer ready-to-launch baby products."
                </p>
              </div>
              <ul class="space-y-2 mb-6">
                {['50+ Ready-made Designs', 'Rapid Prototyping (7 Days)', 'Patent-Protected Models', 'Full IP Protection'].map((item) => (
                  <li key={item} class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-green-300" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a href="/oem-odm#odm" class="inline-flex items-center text-sm font-semibold border border-white/30 px-4 py-2 rounded-lg hover:bg-white/10 transition-colors group-hover:translate-x-1">
                View Catalog
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "Service",
              "@id": "#oem-service",
              "name": "OEM Private Label Manufacturing",
              "description": "Bring your brand to life with our certified production lines. Logo embroidery, custom packaging, material selection available. MOQ: 50 Units.",
              "provider": {
                "@type": "Organization",
                "name": "B2Bbaby",
                "description": "China's leading baby product manufacturer and sourcing partner"
              },
              "serviceType": "Private Label Manufacturing",
              "areaServed": "Global",
              "offers": {
                "@type": "Offer",
                "name": "OEM Service",
                "description": "Baby stroller private label manufacturer service",
                "price": "Custom",
                "priceCurrency": "USD"
              }
            },
            {
              "@type": "Service",
              "@id": "#odm-service",
              "name": "ODM Custom Design & Development",
              "description": "No design? No problem. We offer ready-to-launch baby products with 50+ ready-made designs, rapid prototyping in 7 days, patent-protected models, and full IP protection.",
              "provider": {
                "@type": "Organization",
                "name": "B2Bbaby",
                "description": "China's leading baby product manufacturer and sourcing partner"
              },
              "serviceType": "Product Design Service",
              "areaServed": "Global",
              "offers": {
                "@type": "Offer",
                "name": "ODM Service",
                "description": "Baby product design service, ODM baby gear supplier",
                "price": "Custom",
                "priceCurrency": "USD"
              }
            }
          ]
        }
      </script>
    </section>

    <!-- Procurement Process Section -->
    <section class="py-24 bg-gradient-to-br from-blue-50 to-indigo-50">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 rounded-full text-sm font-semibold mb-4">
            How It Works
          </span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Simple Procurement Process</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            From inquiry to delivery, we've streamlined every step for your convenience
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-6">
          {[
            { step: '01', title: 'Inquiry', desc: 'Tell us your product requirements and quantity' },
            { step: '02', title: 'Sample', desc: 'We send you samples for approval (3-7 days)' },
            { step: '03', title: 'Order', desc: 'Place your order with 30% deposit' },
            { step: '04', title: 'Production', desc: 'Mass production with full QC (15-25 days)' },
            { step: '05', title: 'Delivery', desc: 'Balance paid, goods shipped to your port' }
          ].map((item, idx) => (
            <div key={idx} class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all relative">
              <div class="text-5xl font-bold text-blue-100 mb-4">{item.step}</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-sm text-gray-600">{item.desc}</p>
              {idx < 4 && (
                <div class="hidden lg:block absolute -right-3 top-1/2 -translate-y-1/2">
                  <svg class="w-6 h-6 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Business Terms Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-1.5 bg-indigo-100 text-indigo-700 rounded-full text-sm font-semibold mb-4">
            Business Terms
          </span>
