---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="OEM/ODM Customization - B2Bbaby" description="Professional OEM/ODM customization services for baby products brand">
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <h1 class="text-4xl font-bold text-center mb-4">OEM/ODM Customization</h1>
      <p class="text-xl text-neutral-600 text-center mb-12 max-w-2xl mx-auto">
        Professional customization services for your baby products brand.
        Last Updated: 2026
      </p>
    
    <div class="max-w-4xl mx-auto space-y-12">
      <article>
        <h2 class="text-2xl font-bold mb-6">Our Customization Process</h2>
        <div class="grid md:grid-cols-4 gap-6">
          {[
            { step: 1, title: 'Submit Requirements', desc: 'Send design, specs, or ideas' },
            { step: 2, title: 'Sample Confirmation', desc: '3-5 days sample production' },
            { step: 3, title: 'Mass Production', desc: 'QC at every stage' },
            { step: 4, title: 'Shipment & Support', desc: 'On-time delivery' }
          ].map((item) => (
            <div key={item.step} class="bg-white border border-neutral-200 rounded-lg p-6 text-center">
              <div class="bg-primary-600 text-white w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 font-bold text-xl">
                {item.step}
              </div>
              <h3 class="font-semibold mb-2">{item.title}</h3>
              <p class="text-sm text-neutral-600">{item.desc}</p>
            </div>
          ))}
        </div>
      </article>
      
      <article class="bg-white border border-neutral-200 rounded-lg p-8">
        <h2 class="text-2xl font-bold mb-6">Customization Options</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {[
            'Custom logo printing',
            'Color customization',
            'Packaging design',
            'Product modifications',
            'Exclusive labeling',
            'Custom specifications'
          ].map((item, idx) => (
            <div key={idx} class="flex items-start gap-3">
              <span class="text-primary-600 text-xl">✓</span>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </article>

      <article>
        <h2 class="text-2xl font-bold mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {[
            {
              question: 'What is the minimum order for OEM/private label?',
              answer: 'OEM minimums: Logo only - 100 units per model, Custom packaging - 500 units, Custom color - 100 units per color, Full custom product - 500-1000 units (depends on complexity). We are flexible for promising brands and can phase in higher volumes over time.'
            },
            {
              question: 'What is the cost for OEM customization?',
              answer: 'OEM costs vary: Logo printing - $0.30-$1.00 per unit (MOQ 100), Custom packaging - $1.50-$3.00 per unit (MOQ 500), Custom color - +5% (MOQ 100 per color), New mold - $5,000-$20,000 (amortized over orders). We will provide a detailed quote based on your requirements.'
            },
            {
              question: 'Can you help with product development and design?',
              answer: 'Yes, we have an in-house R&D team that can help with: Concept development, 3D CAD modeling, Prototype making, Testing and validation, Design for manufacturing (DFM). We love working on innovative new products!'
            }
          ].map((faq, idx) => (
            <div key={idx} class="bg-white border border-neutral-200 rounded-lg p-6">
              <h3 class="text-lg font-semibold mb-2">{faq.question}</h3>
              <p class="text-neutral-600">{faq.answer}</p>
            </div>
          ))}
          <div class="text-center mt-4">
            <a href="/faq" class="text-primary-600 font-semibold hover:underline">
              View all FAQs →
            </a>
          </div>
        </div>
      </article>
      
      <div class="text-center">
        <a href="/contact" class="bg-blue-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-800 transition inline-block text-lg">
          Start Your Customization Project
        </a>
      </div>
    </div>
  </div>
  </section>
</Layout>