---
import Layout from '@/layouts/Layout.astro';
import { generateServiceSchema } from '@/lib/schema';

const serviceSchema = generateServiceSchema('oem-odm');
---

<Layout title="OEM/ODM Customization - B2Bbaby | Custom Baby Products Manufacturing" description="Professional OEM/ODM customization services for baby products brand. Custom logo, packaging, color options available.">
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  
  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-10 md:py-16">
    <div class="container mx-auto px-4 md:px-6">
      <div class="text-center">
        <span class="inline-block bg-white/80 backdrop-blur-sm px-4 py-1 rounded-full text-sm font-medium text-blue-700 mb-4">
          OEM/ODM
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4">OEM/ODM Customization</h1>
        <p class="text-base md:text-lg text-neutral-600 max-w-2xl mx-auto">
          Professional customization services for your baby products brand.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto space-y-12">
        <article>
          <div class="text-center mb-8">
            <h2 class="text-xl md:text-2xl font-bold text-neutral-900">Our Customization Process</h2>
          </div>
          <div class="grid md:grid-cols-4 gap-6">
            {[
              { step: 1, title: 'Submit Requirements', desc: 'Send design, specs, or ideas' },
              { step: 2, title: 'Sample Confirmation', desc: '3-5 days sample production' },
              { step: 3, title: 'Mass Production', desc: 'QC at every stage' },
              { step: 4, title: 'Shipment & Support', desc: 'On-time delivery' }
            ].map((item) => (
              <div key={item.step} class="bg-white border border-neutral-200 rounded-2xl p-6 text-center hover:shadow-lg transition-shadow">
                <div class="bg-blue-600 text-white w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4 font-bold text-xl">
                  {item.step}
                </div>
                <h3 class="font-semibold text-lg mb-2">{item.title}</h3>
                <p class="text-sm text-neutral-600">{item.desc}</p>
              </div>
            ))}
          </div>
        </article>
        
        <article class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-6 md:p-8 border border-blue-100">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Customization Options</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {[
              'Custom logo printing',
              'Color customization',
              'Packaging design',
              'Product modifications',
              'Exclusive labeling',
              'Custom specifications'
            ].map((item, idx) => (
              <div key={idx} class="flex items-center gap-3 bg-white p-4 rounded-xl">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="font-medium text-neutral-700">{item}</span>
              </div>
            ))}
          </div>
        </article>

        <article>
          <div class="text-center mb-8">
            <h2 class="text-xl md:text-2xl font-bold text-neutral-900">Frequently Asked Questions</h2>
          </div>
          <div class="space-y-4">
            {[
              {
                question: 'What is the minimum order for OEM/private label?',
                answer: 'OEM minimums: Logo only - 100 units per model, Custom packaging - 500 units, Custom color - 100 units per color, Full custom product - 500-1000 units (depends on complexity). We are flexible for promising brands and can phase in higher volumes over time.'
              },
              {
                question: 'What is the cost for OEM customization?',
                answer: 'OEM costs vary: Logo printing - $0.30-$1.00 per unit (MOQ 100), Custom packaging - $1.50-$3.00 per unit (MOQ 500), Custom color - +5% (MOQ 100 per color), New mold - $5,000-$20,000 (amortized over orders). We will provide a detailed quote based on your requirements.'
              },
              {
                question: 'Can you help with product development and design?',
                answer: 'Yes, we have an in-house R&D team that can help with: Concept development, 3D CAD modeling, Prototype making, Testing and validation, Design for manufacturing (DFM). We love working on innovative new products!'
              }
            ].map((faq, idx) => (
              <div key={idx} class="bg-white border border-neutral-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
                <h3 class="text-lg font-semibold text-neutral-900 mb-2">{faq.question}</h3>
                <p class="text-neutral-600 text-sm md:text-base">{faq.answer}</p>
              </div>
            ))}
            <div class="text-center mt-4">
              <a href="/faq" class="inline-flex items-center gap-2 text-blue-600 font-semibold hover:text-blue-700">
                View all FAQs
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
        
        <div class="text-center">
          <a href="/contact" class="inline-flex items-center gap-2 bg-gradient-primary text-white px-8 py-4 rounded-xl font-semibold hover:opacity-90 transition-all text-lg">
            Start Your Customization Project
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>