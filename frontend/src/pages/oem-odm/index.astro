---
import Layout from '@/layouts/Layout.astro';
import { generateServiceSchema } from '@/lib/schema';

const serviceSchema = generateServiceSchema('oem-odm');
---

<Layout title="OEM/ODM Customization - B2Bbaby | Custom Baby Products Manufacturing" description="Professional OEM/ODM customization services for baby products brand. Custom logo, packaging, color options available.">
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  
  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-10 md:py-16">
    <div class="container mx-auto px-4 md:px-6">
      <div class="text-center">
        <span class="inline-block bg-white/80 backdrop-blur-sm px-4 py-1 rounded-full text-sm font-medium text-blue-700 mb-4">
          OEM/ODM
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4">OEM/ODM Customization</h1>
        <p class="text-base md:text-lg text-neutral-600 max-w-2xl mx-auto">
          Professional customization services for your baby products brand.
        </p>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4 md:px-6">
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="#oem" class="px-6 py-3 bg-orange-500 text-white rounded-xl font-semibold hover:bg-orange-600 transition-colors">
          OEM Service
        </a>
        <a href="#odm" class="px-6 py-3 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition-colors">
          ODM Service
        </a>
        <a href="#quote" class="px-6 py-3 bg-green-600 text-white rounded-xl font-semibold hover:bg-green-700 transition-colors">
          Request Quote
        </a>
        <a href="#nda" class="px-6 py-3 bg-purple-600 text-white rounded-xl font-semibold hover:bg-purple-700 transition-colors">
          Request NDA
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-5xl mx-auto">
        <article id="oem" class="mb-16">
          <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-orange-100 text-orange-700 rounded-full text-sm font-semibold mb-4">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
              OEM Service
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-neutral-900">Private Label Manufacturing</h2>
            <p class="text-neutral-600 mt-2 max-w-2xl mx-auto">
              Bring your brand to life with our ISO 9001 certified production lines. From concept to delivery, we handle everything.
            </p>
          </div>

          <div class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-2xl p-6 md:p-8 mb-8">
            <h3 class="text-xl font-bold text-neutral-900 mb-6">OEM Production Flow</h3>
            <div class="grid md:grid-cols-5 gap-4">
              {[
                { step: '01', title: 'Design Confirm', desc: 'Review and approve design specs' },
                { step: '02', title: 'Sample Making', desc: '3-5 days for prototype' },
                { step: '03', title: 'Mass Production', desc: 'QC at every stage' },
                { step: '04', title: 'Quality Inspection', desc: 'Final QA before shipment' },
                { step: '05', title: 'Delivery', desc: 'On-time shipment worldwide' }
              ].map((item) => (
                <div key={item.step} class="bg-white rounded-xl p-4 text-center shadow-sm">
                  <div class="bg-orange-500 text-white w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-3 font-bold">
                    {item.step}
                  </div>
                  <h4 class="font-semibold text-neutral-900 mb-1">{item.title}</h4>
                  <p class="text-xs text-neutral-500">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white border border-gray-200 rounded-2xl p-6">
              <h3 class="text-lg font-bold text-neutral-900 mb-4">Packaging Options</h3>
              <div class="space-y-3">
                {['Custom printed boxes', 'Branded polybags', 'Gift boxes with logo', 'Retail-ready packaging', 'Bulk packaging options'].map((item, idx) => (
                  <div key={idx} class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-neutral-700">{item}</span>
                  </div>
                ))}
              </div>
            </div>
            
            <div class="bg-white border border-gray-200 rounded-2xl p-6">
              <h3 class="text-lg font-bold text-neutral-900 mb-4">MOQ Tier Pricing</h3>
              <div class="space-y-3">
                {[
                  { tier: '50-199', price: 'Standard', lead: '15-20 days' },
                  { tier: '200-499', price: '5% Discount', lead: '12-15 days' },
                  { tier: '500-999', price: '10% Discount', lead: '10-12 days' },
                  { tier: '1000+', price: '15% Discount', lead: '7-10 days' }
                ].map((item, idx) => (
                  <div key={idx} class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
                    <span class="font-medium text-neutral-900">{item.tier} units</span>
                    <div class="text-right">
                      <div class="text-sm font-semibold text-orange-600">{item.price}</div>
                      <div class="text-xs text-neutral-500">{item.lead}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="text-center">
            <a href="#quote" class="inline-flex items-center gap-2 bg-orange-500 text-white px-8 py-4 rounded-xl font-semibold hover:bg-orange-600 transition-colors">
              Start Your OEM Project
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>

        <article id="odm" class="mb-16">
          <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100 text-blue-700 rounded-full text-sm font-semibold mb-4">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
              </svg>
              ODM Service
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-neutral-900">Custom Design & Development</h2>
            <p class="text-neutral-600 mt-2 max-w-2xl mx-auto">
              No design? No problem. We offer ready-to-launch baby products with full IP protection.
            </p>
          </div>

          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-6 md:p-8 mb-8">
            <h3 class="text-xl font-bold text-neutral-900 mb-6">Design Gallery</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              {[
                { name: 'Design #1', src: '/images/designs/design-1.jpg' },
                { name: 'Design #2', src: '/images/designs/design-2.jpg' },
                { name: 'Design #3', src: '/images/designs/design-3.jpg' },
                { name: 'Design #4', src: '/images/designs/design-4.jpg' }
              ].map((item, idx) => (
                <div key={idx} class="bg-white rounded-xl overflow-hidden shadow-sm group hover:shadow-md transition-shadow">
                  <div class="aspect-square bg-gray-100">
                    <img 
                      src={item.src}
                      alt={item.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-3 text-center">
                    <span class="text-sm font-medium text-neutral-700">{item.name}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white border border-gray-200 rounded-2xl p-6">
              <h3 class="text-lg font-bold text-neutral-900 mb-4">Patent Certifications</h3>
              <div class="space-y-3">
                {['CN Patent: Baby Stroller Safety Lock', 'CN Patent: Foldable Gate Design', 'EU Design Registration', 'US Design Patent Pending'].map((item, idx) => (
                  <div key={idx} class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    <span class="text-neutral-700 text-sm">{item}</span>
                  </div>
                ))}
              </div>
            </div>
            
            <div class="bg-white border border-gray-200 rounded-2xl p-6">
              <h3 class="text-lg font-bold text-neutral-900 mb-4">Prototype Timeline</h3>
              <div class="space-y-3">
                {[
                  { day: 'Day 1-3', task: 'Design Review & Confirmation' },
                  { day: 'Day 4-6', task: '3D Modeling & Prototyping' },
                  { day: 'Day 7', task: 'Sample Ready for Shipment' }
                ].map((item, idx) => (
                  <div key={idx} class="flex items-start gap-3">
                    <div class="bg-blue-500 text-white px-3 py-1 rounded-lg text-sm font-bold">
                      {item.day}
                    </div>
                    <span class="text-neutral-700 pt-1">{item.task}</span>
                  </div>
                ))}
              </div>
              <div class="mt-6 p-4 bg-gray-50 rounded-lg">
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                  <span class="text-sm text-neutral-600">Standard lead time: 7 days</span>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-2xl p-6 text-white">
            <h3 class="text-lg font-bold mb-3">NDA Agreement Available</h3>
            <p class="text-blue-100 text-sm mb-4">
              We offer Non-Disclosure Agreements to protect your intellectual property. Contact us to request a copy.
            </p>
            <a href="#nda" class="inline-flex items-center gap-2 bg-white text-blue-600 px-6 py-2 rounded-lg font-semibold hover:bg-blue-50 transition-colors text-sm">
              Request NDA Template
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>

        <article id="quote" class="mb-16 scroll-mt-20">
          <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-100 text-green-700 rounded-full text-sm font-semibold mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
              Request Quote
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-neutral-900">Get Your Custom Quote</h2>
            <p class="text-neutral-600 mt-2 max-w-2xl mx-auto">
              Fill out the form below and our team will get back to you within 24 hours.
            </p>
          </div>

          <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-2xl p-6 md:p-8 border border-green-100">
            <form id="oem-quote-form" class="space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="company" class="block text-sm font-semibold text-neutral-900 mb-2">Company Name *</label>
                  <input type="text" id="company" name="company" required
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all"
                    placeholder="Your company name" />
                </div>
                <div>
                  <label for="contact" class="block text-sm font-semibold text-neutral-900 mb-2">Contact Person *</label>
                  <input type="text" id="contact" name="contact" required
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all"
                    placeholder="Your name" />
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-semibold text-neutral-900 mb-2">Email *</label>
                  <input type="email" id="email" name="email" required
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all"
                    placeholder="your@email.com" />
                </div>
                <div>
                  <label for="whatsapp" class="block text-sm font-semibold text-neutral-900 mb-2">WhatsApp (optional)</label>
                  <input type="tel" id="whatsapp" name="whatsapp"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all"
                    placeholder="+86 123 4567 8900" />
                </div>
              </div>

              <div>
                <label for="serviceType" class="block text-sm font-semibold text-neutral-900 mb-2">Service Type *</label>
                <select id="serviceType" name="serviceType" required
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all bg-white">
                  <option value="">Select a service...</option>
                  <option value="oem">OEM - Private Label</option>
                  <option value="odm">ODM - Custom Design</option>
                  <option value="both">Both OEM & ODM</option>
                </select>
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="productType" class="block text-sm font-semibold text-neutral-900 mb-2">Product Type</label>
                  <select id="productType" name="productType"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all bg-white">
                    <option value="">Select product type...</option>
                    <option value="stroller">Baby Stroller</option>
                    <option value="gate">Safety Gate</option>
                    <option value="highchair">High Chair</option>
                    <option value="bedrail">Bed Rail</option>
                    <option value="other">Other Baby Products</option>
                  </select>
                </div>
                <div>
                  <label for="quantity" class="block text-sm font-semibold text-neutral-900 mb-2">Estimated Quantity</label>
                  <select id="quantity" name="quantity"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all bg-white">
                    <option value="">Select quantity range...</option>
                    <option value="50-199">50-199 units</option>
                    <option value="200-499">200-499 units</option>
                    <option value="500-999">500-999 units</option>
                    <option value="1000+">1000+ units</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="customization" class="block text-sm font-semibold text-neutral-900 mb-2">Customization Details</label>
                <textarea id="customization" name="customization" rows="4"
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all resize-vertical"
                  placeholder="Tell us about your customization needs: logo, packaging, colors, special features, target market, certifications required, etc."></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="newsletter" name="newsletter"
                  class="w-5 h-5 rounded border-neutral-300 text-green-600 focus:ring-green-500 mt-0.5" />
                <label for="newsletter" class="text-sm text-neutral-600">
                  I'd like to receive updates about new products and special offers
                </label>
              </div>

              <div class="text-center">
                <button type="submit"
                  class="inline-flex items-center justify-center gap-2 bg-green-600 text-white px-10 py-4 rounded-xl font-semibold hover:bg-green-700 transition-all hover:shadow-lg transform hover:-translate-y-0.5">
                  Send Quote Request
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                  </svg>
                </button>
              </div>
            </form>

            <div id="quoteSuccess" class="hidden mt-6 p-6 bg-green-100 text-green-800 rounded-xl text-center">
              <div class="text-4xl mb-3">✅</div>
              <h3 class="text-xl font-bold mb-2">Thank You!</h3>
              <p>Your quote request has been submitted. Our team will contact you within 24 hours.</p>
            </div>
          </div>
        </article>

        <article id="nda" class="scroll-mt-20">
          <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-purple-100 text-purple-700 rounded-full text-sm font-semibold mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
              Request NDA
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-neutral-900">Protect Your Intellectual Property</h2>
            <p class="text-neutral-600 mt-2 max-w-2xl mx-auto">
              Request a Non-Disclosure Agreement before sharing sensitive information about your project.
            </p>
          </div>

          <div class="bg-gradient-to-br from-purple-50 to-violet-50 rounded-2xl p-6 md:p-8 border border-purple-100">
            <form id="nda-form" class="space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="ndaCompany" class="block text-sm font-semibold text-neutral-900 mb-2">Company Name *</label>
                  <input type="text" id="ndaCompany" name="ndaCompany" required
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none transition-all"
                    placeholder="Your company name" />
                </div>
                <div>
                  <label for="ndaContact" class="block text-sm font-semibold text-neutral-900 mb-2">Contact Person *</label>
                  <input type="text" id="ndaContact" name="ndaContact" required
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none transition-all"
                    placeholder="Your name" />
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="ndaEmail" class="block text-sm font-semibold text-neutral-900 mb-2">Email *</label>
                  <input type="email" id="ndaEmail" name="ndaEmail" required
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none transition-all"
                    placeholder="your@email.com" />
                </div>
                <div>
                  <label for="ndaType" class="block text-sm font-semibold text-neutral-900 mb-2">NDA Type</label>
                  <select id="ndaType" name="ndaType"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none transition-all bg-white">
                    <option value="unilateral">Unilateral (One-way)</option>
                    <option value="mutual">Mutual (Two-way)</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="ndaProject" class="block text-sm font-semibold text-neutral-900 mb-2">Brief Project Description</label>
                <textarea id="ndaProject" name="ndaProject" rows="3"
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none transition-all resize-vertical"
                  placeholder="What type of project are you working on? (General description is fine at this stage)"></textarea>
              </div>

              <div class="text-center">
                <button type="submit"
                  class="inline-flex items-center justify-center gap-2 bg-purple-600 text-white px-10 py-4 rounded-xl font-semibold hover:bg-purple-700 transition-all hover:shadow-lg transform hover:-translate-y-0.5">
                  Request NDA
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                  </svg>
                </button>
              </div>
            </form>

            <div id="ndaSuccess" class="hidden mt-6 p-6 bg-purple-100 text-purple-800 rounded-xl text-center">
              <div class="text-4xl mb-3">📄</div>
              <h3 class="text-xl font-bold mb-2">NDA Request Sent!</h3>
              <p>Our team will send you the NDA document for review within 24 hours.</p>
            </div>

            <div class="mt-8 p-6 bg-white rounded-xl border border-purple-100">
              <h3 class="font-bold text-neutral-900 mb-4">What Our NDA Covers</h3>
              <div class="grid md:grid-cols-2 gap-4">
                {[
                  { icon: '🔒', title: 'Confidential Information', desc: 'Product designs, specifications, and business information' },
                  { icon: '💡', title: 'IP Protection', desc: 'Your ideas, patents, and proprietary technology' },
                  { icon: '🤝', title: 'Mutual Benefit', desc: 'Protects both parties during collaboration' },
                  { icon: '⚖️', title: 'Legal Recourse', desc: 'Clear terms for dispute resolution' }
                ].map((item, idx) => (
                  <div key={idx} class="flex gap-3">
                    <span class="text-2xl">{item.icon}</span>
                    <div>
                      <h4 class="font-semibold text-neutral-900">{item.title}</h4>
                      <p class="text-sm text-neutral-600">{item.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('oem-quote-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const button = this.querySelector('button[type="submit"]');
      const originalText = button.textContent;
      button.textContent = 'Submitting...';
      button.disabled = true;
      
      try {
        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        
        const apiUrl = '/api/send-email.json';
        
        const response = await fetch(apiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ ...data, type: 'oem-quote' }),
        });
        
        if (response.ok) {
          const result = await response.json();
          
          if (result.success) {
            document.getElementById('quoteSuccess').classList.remove('hidden');
            document.getElementById('quoteSuccess').scrollIntoView({ behavior: 'smooth' });
            this.reset();
          } else {
            alert('Failed to submit quote request. Please try again later.');
          }
        } else {
          alert('API endpoint not found. Please check server configuration.');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Failed to submit quote request. Please try again later.');
      } finally {
        button.textContent = originalText;
        button.disabled = false;
      }
    });

