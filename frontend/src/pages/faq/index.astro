---
import Layout from '@/layouts/Layout.astro';
import { faqs, faqCategories } from '@/lib/faq-data';
import { generateFAQPageSchema } from '@/lib/schema';

const faqPageSchema = generateFAQPageSchema(faqs);
---

<Layout title="FAQ - B2Bbaby | Baby Products Sourcing Questions" description="Frequently asked questions about our baby products, services, and ordering process. Get answers to your sourcing questions.">
  <div>
    <script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />
    
    <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-10 md:py-16">
      <div class="container mx-auto px-4 md:px-6">
        <div class="text-center">
          <span class="inline-block bg-white/80 backdrop-blur-sm px-4 py-1 rounded-full text-sm font-medium text-purple-700 mb-4">
            FAQ
          </span>
          <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4">Frequently Asked Questions</h1>
          <p class="text-base md:text-lg text-neutral-600 max-w-2xl mx-auto">
            Find answers to common questions about our products, services, and ordering process.
          </p>
        </div>
      </div>
    </section>

    <section class="py-12 md:py-20 bg-white">
      <div class="container mx-auto px-4 md:px-6">
        <div class="flex flex-wrap justify-center gap-3 mb-10">
          {faqCategories.map((category) => (
            <button
              key={category}
              onClick={(e) => {
                const buttons = document.querySelectorAll('.faq-category-btn');
                buttons.forEach(btn => btn.classList.remove('bg-blue-600', 'text-white', 'shadow-lg'));
                buttons.forEach(btn => btn.classList.add('bg-neutral-100', 'text-neutral-600', 'hover:bg-blue-100'));
                e.target.classList.remove('bg-neutral-100', 'text-neutral-600', 'hover:bg-blue-100');
                e.target.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
                
                const articles = document.querySelectorAll('.faq-item');
                articles.forEach(article => {
                  if (category === 'All') {
                    article.style.display = 'block';
                  } else {
                    const articleCategory = article.getAttribute('data-category');
                    article.style.display = articleCategory === category ? 'block' : 'none';
                  }
                });
              }}
              class={`faq-category-btn px-6 py-3 rounded-xl font-medium transition-all ${
                category === 'All'
                  ? 'bg-blue-600 text-white shadow-lg'
                  : 'bg-neutral-100 text-neutral-600 hover:bg-blue-100'
              }`}
            >
              {category}
            </button>
          ))}
        </div>
        
        <div class="max-w-3xl mx-auto space-y-4">
          {faqs.map((faq, idx) => (
            <article 
              key={faq.id} 
              class="faq-item bg-white border border-neutral-200 rounded-2xl overflow-hidden hover:border-blue-200 hover:shadow-md transition-all"
              data-category={faq.category}
            >
              <button
                onClick={() => {
                  const content = document.getElementById(`faq-content-${faq.id}`);
                  const icon = document.getElementById(`faq-icon-${faq.id}`);
                  const article = document.querySelector(`[data-faq-id="${faq.id}"]`);
                  
                  if (content.style.display === 'none' || content.style.display === '') {
                    content.style.display = 'block';
                    icon.setAttribute('transform', 'rotate(180)');
                    article.classList.add('border-blue-300');
                  } else {
                    content.style.display = 'none';
                    icon.setAttribute('transform', 'rotate(0)');
                    article.classList.remove('border-blue-300');
                  }
                }}
                class="w-full flex items-center justify-between p-5 md:p-6 text-left"
                data-faq-id={faq.id}
              >
                <h2 class="text-base md:text-lg font-semibold text-neutral-900 pr-4">{faq.question}</h2>
                <svg 
                  id={`faq-icon-${faq.id}`}
                  xmlns="http://www.w3.org/2000/svg" 
                  width="20" 
                  height="20" 
                  viewBox="0 0 24 24" 
                  fill="none" 
                  stroke="currentColor" 
                  stroke-width="2"
                  class="text-neutral-400 transition-transform duration-300 flex-shrink-0"
                  style={{ transform: 'rotate(0)' }}
                >
                  <path d="M6 9h12M6 15h12M12 12l-3-3 3-3"/>
                </svg>
              </button>
              <div 
                id={`faq-content-${faq.id}`} 
                class="px-5 md:px-6 pb-5 md:pb-6"
                style={{ display: idx === 0 ? 'block' : 'none' }}
              >
                <p class="text-neutral-600 text-sm md:text-base leading-relaxed">{faq.answer}</p>
                <div class="flex justify-between items-center mt-4 pt-4 border-t border-neutral-100">
                  <span class="text-xs text-neutral-400">Category: {faq.category}</span>
                  <span class="text-xs text-neutral-400">Last Updated: 2026</span>
                </div>
              </div>
            </article>
          ))}
        </div>
        
        <div class="text-center mt-12">
          <p class="text-neutral-600 mb-4">Still have questions?</p>
          <a href="/contact" class="inline-flex items-center gap-2 bg-blue-600 text-white px-8 py-4 rounded-xl font-semibold hover:bg-blue-700 transition-all">
            Contact Us
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>