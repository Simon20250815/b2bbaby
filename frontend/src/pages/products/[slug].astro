---
import Layout from '@/layouts/Layout.astro';
import { productsData, getProductBySlug } from '@/lib/product-data';
import { generateProductSchema } from '@/lib/schema';

export function getStaticPaths() {
  return productsData.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

if (!product) {
  return Astro.redirect('/products');
}

const productSchema = generateProductSchema(product);

const relatedProducts = productsData
  .filter(p => p.slug !== product.slug && p.category === product.category)
  .slice(0, 3);
---

<Layout title={`${product.title} - B2Bbaby`} description={product.description}>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  
  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-12">
    <div class="container mx-auto px-6">
      <nav class="text-sm text-neutral-500 mb-4">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-blue-600">Products</a>
        <span class="mx-2">/</span>
        <span class="text-neutral-800">{product.title}</span>
      </nav>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12">
        <div class="product-gallery">
          <div class="main-image rounded-xl overflow-hidden shadow-lg mb-4">
            <img 
              src={product.image} 
              alt={product.title}
              class="w-full h-96 object-cover"
              id="mainImage"
            />
          </div>
          <div class="grid grid-cols-5 gap-2">
            {product.galleryImages.map((img, idx) => (
              <button 
                class={`thumbnail rounded-lg overflow-hidden border-2 transition ${idx === 0 ? 'border-blue-500' : 'border-transparent hover:border-blue-300'}`}
                onclick={`document.getElementById('mainImage').src='${img}'; document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('border-blue-500')); this.classList.add('border-blue-500')`}
              >
                <img src={img} alt={`${product.title} view ${idx + 1}`} class="w-full h-16 object-cover" />
              </button>
            ))}
          </div>
        </div>

        <div class="product-info">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">
              MOQ: {product.moq} PCS
            </span>
            {product.certifications.slice(0, 2).map(cert => (
              <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm">
                {cert}
              </span>
            ))}
          </div>

          <h1 class="text-3xl font-bold text-neutral-900 mb-4">{product.title}</h1>
          
          <p class="text-lg text-neutral-600 mb-6 leading-relaxed">{product.description}</p>

          <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="bg-neutral-50 rounded-lg p-4 text-center">
              <div class="text-2xl font-bold text-blue-600">{product.exportBatches}+</div>
              <div class="text-sm text-neutral-500">Export Batches</div>
            </div>
            <div class="bg-neutral-50 rounded-lg p-4 text-center">
              <div class="text-2xl font-bold text-green-600">{product.zeroReturnRate ? '100%' : '98%'}</div>
              <div class="text-sm text-neutral-500">Return Rate</div>
            </div>
            <div class="bg-neutral-50 rounded-lg p-4 text-center">
              <div class="text-2xl font-bold text-purple-600">{product.targetMarkets.length}</div>
              <div class="text-sm text-neutral-500">Markets</div>
            </div>
          </div>

          <div class="border-t pt-6">
            <h3 class="font-semibold mb-3">Target Markets:</h3>
            <div class="flex flex-wrap gap-2 mb-6">
              {product.targetMarkets.map(market => (
                <span class="bg-neutral-100 px-3 py-1 rounded-full text-sm">{market}</span>
              ))}
            </div>
          </div>

          <div class="bg-blue-50 rounded-xl p-6 border border-blue-100">
            <h3 class="font-semibold text-blue-800 mb-4">Get Quotation Now</h3>
            <div class="grid grid-cols-2 gap-4 text-sm">
              <div>
                <span class="text-neutral-500">Sample Lead Time:</span>
                <span class="ml-2 font-medium">{product.leadTimeSample}</span>
              </div>
              <div>
                <span class="text-neutral-500">Production Lead Time:</span>
                <span class="ml-2 font-medium">{product.leadTimeProduction}</span>
              </div>
            </div>
            <a 
              href={`/contact?product=${product.slug}`}
              class="mt-4 block w-full bg-blue-600 text-white text-center py-3 rounded-lg font-semibold hover:bg-blue-700 transition"
            >
              Request Quote
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-neutral-50">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12">
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Product Specifications
          </h2>
          <div class="space-y-3">
            {Object.entries(product.specs).map(([key, value]) => (
              <div class="flex justify-between py-2 border-b border-neutral-100 last:border-0">
                <span class="text-neutral-500">{key}</span>
                <span class="font-medium text-neutral-800">{value}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
            Key Features
          </h2>
          <ul class="space-y-3">
            {product.features.map(feature => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-neutral-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            OEM/ODM Customization Options
          </h2>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-6 border border-blue-100">
            <div class="grid gap-4">
              {Object.entries(product.customOptions).map(([key, value]) => (
                <div class="flex items-center gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="font-medium text-neutral-700">{key}:</span>
                  <span class="text-neutral-600">{value}</span>
                </div>
              ))}
            </div>
            <a 
              href="/oem-odm" 
              class="mt-6 inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 font-medium"
            >
              Learn more about OEM/ODM services
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            Certifications & Testing
          </h2>
          <div class="grid grid-cols-2 gap-4 mb-6">
            {product.certifications.map(cert => (
              <div class="bg-green-50 rounded-lg p-4 border border-green-200 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="font-semibold text-green-800">{cert}</span>
              </div>
            ))}
          </div>
          {product.testReportNumber && (
            <p class="text-sm text-neutral-500">
              Test Report Number: <span class="font-mono font-medium">{product.testReportNumber}</span>
            </p>
          )}
        </div>
      </div>
    </div>
  </section>

  {product.applications && product.applications.length > 0 && (
    <section class="py-12 bg-neutral-50">
      <div class="container mx-auto px-6">
        <h2 class="text-2xl font-bold mb-6">Application Scenarios</h2>
        <div class="grid md:grid-cols-4 gap-4">
          {product.applications.map(app => (
            <div class="bg-white rounded-lg p-4 text-center shadow-sm">
              <span class="text-neutral-700">{app}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {relatedProducts.length > 0 && (
    <section class="py-12 bg-white">
      <div class="container mx-auto px-6">
        <h2 class="text-2xl font-bold mb-8">Related Products</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedProducts.map(p => (
            <a href={`/products/${p.slug}`} class="group">
              <div class="bg-neutral-50 rounded-xl overflow-hidden transition group-hover:shadow-lg">
                <div class="h-48 overflow-hidden">
                  <img src={p.image} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition" />
                </div>
                <div class="p-4">
                  <h3 class="font-semibold group-hover:text-blue-600 transition">{p.title}</h3>
                  <p class="text-sm text-neutral-500 mt-1">MOQ: {p.moq} PCS</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-16 bg-gradient-to-r from-blue-600 to-indigo-600">
    <div class="container mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Source This Product?</h2>
      <p class="text-blue-100 mb-8 max-w-2xl mx-auto">Get a free quotation with detailed pricing, sample availability, and customized solutions for your brand.</p>
      <div class="flex justify-center gap-4">
        <a href={`/contact?product=${product.slug}`} class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition">
          Get Quote Now
        </a>
        <a href="/contact" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>