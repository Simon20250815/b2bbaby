---
import Layout from '@/layouts/Layout.astro';
import { productsData, getProductBySlug } from '@/lib/product-data';
import { getProductBySlug as getDirectusProduct, getProducts as getDirectusProducts } from '@/lib/directus';
import { generateProductSchema } from '@/lib/schema';

export async function getStaticPaths() {
  const directusProducts = await getDirectusProducts();
  const allProducts = directusProducts.length > 0 ? directusProducts : productsData;
  
  return allProducts.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

if (!product) {
  return Astro.redirect('/products');
}

const productSchema = generateProductSchema(product);

const allProducts = await getDirectusProducts();
const availableProducts = allProducts.length > 0 ? allProducts : productsData;
const relatedProducts = availableProducts
  .filter(p => p.slug !== product.slug && p.category === product.category)
  .slice(0, 3);
---

<Layout title={`${product.title} - B2Bbaby | MOQ ${product.moq} PCS`} description={product.description}>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  
  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-8">
    <div class="container mx-auto px-4 md:px-6">
      <nav class="flex items-center gap-2 text-sm text-neutral-600">
        <a href="/" class="hover:text-blue-600 transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <a href="/products" class="hover:text-blue-600 transition-colors">Products</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="text-neutral-900 font-semibold">{product.title}</span>
      </nav>
    </div>
  </section>

  <section class="py-10 md:py-16 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
        <div class="product-gallery">
          <div class="main-image rounded-2xl overflow-hidden shadow-lg mb-4 bg-neutral-100">
            <img 
              src={product.image} 
              alt={product.title}
              class="w-full h-72 md:h-96 object-cover"
              id="mainImage"
            />
          </div>
          <div class="grid grid-cols-5 gap-2">
            {((product.gallery_images || product.galleryImages) || []).map((img, idx) => (
              <button 
                key={idx}
                class={`thumbnail rounded-xl overflow-hidden border-2 transition-all ${idx === 0 ? 'border-blue-500 ring-2 ring-blue-200' : 'border-transparent hover:border-blue-300'}`}
                onclick={`document.getElementById('mainImage').src='${img}'; document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('border-blue-500', 'ring-2', 'ring-blue-200')); this.classList.add('border-blue-500', 'ring-2', 'ring-blue-200')`}
              >
                <img src={img} alt={`${product.title} view ${idx + 1}`} class="w-full h-14 md:h-16 object-cover" loading="lazy" />
              </button>
            ))}
          </div>
        </div>

        <div class="product-info">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="bg-blue-100 text-blue-700 px-4 py-1.5 rounded-full text-sm font-medium">
              MOQ: {product.moq} PCS
            </span>
            {(product.certifications || []).slice(0, 2).map(cert => (
              <span key={cert} class="bg-green-100 text-green-700 px-4 py-1.5 rounded-full text-sm font-medium">
                {cert}
              </span>
            ))}
          </div>

          <h1 class="text-2xl md:text-4xl font-bold text-neutral-900 mb-4">{product.title}</h1>
          
          <p class="text-base md:text-lg text-neutral-600 mb-6 leading-relaxed">{product.description || product.description_en}</p>

          <div class="grid grid-cols-3 gap-3 mb-6">
            <div class="bg-neutral-50 rounded-xl p-4 text-center">
              <div class="text-xl md:text-2xl font-bold text-blue-600">{(product.export_batches || product.exportBatches || 0)}+</div>
              <div class="text-xs md:text-sm text-neutral-500 mt-1">Export Batches</div>
            </div>
            <div class="bg-neutral-50 rounded-xl p-4 text-center">
              <div class="text-xl md:text-2xl font-bold text-green-600">{(product.zero_return_rate || product.zeroReturnRate) ? '0%' : '98%'}</div>
              <div class="text-xs md:text-sm text-neutral-500 mt-1">Return Rate</div>
            </div>
            <div class="bg-neutral-50 rounded-xl p-4 text-center">
              <div class="text-xl md:text-2xl font-bold text-purple-600">{(product.target_markets || product.targetMarkets || []).length}</div>
              <div class="text-xs md:text-sm text-neutral-500 mt-1">Markets</div>
            </div>
          </div>

          <div class="border-t border-neutral-200 pt-5 mb-6">
            <h3 class="font-semibold text-neutral-900 mb-3">Target Markets:</h3>
            <div class="flex flex-wrap gap-2">
              {(product.target_markets || product.targetMarkets || []).map(market => (
                <span key={market} class="bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full text-sm font-medium">
                  {market}
                </span>
              ))}
            </div>
          </div>

          <div class="bg-blue-50 rounded-2xl p-6 border border-blue-100">
            <h3 class="font-semibold text-blue-800 mb-4">Get Quotation Now</h3>
            <div class="grid grid-cols-2 gap-4 text-sm mb-4">
              <div class="flex justify-between">
                <span class="text-neutral-600">Sample Lead Time:</span>
                <span class="font-medium text-neutral-900">{product.lead_time_sample || product.leadTimeSample}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-neutral-600">Production Lead Time:</span>
                <span class="font-medium text-neutral-900">{product.lead_time_production || product.leadTimeProduction}</span>
              </div>
            </div>
            <a 
              href={`/contact?product=${product.slug}`}
              class="block w-full bg-gradient-primary text-white py-3 rounded-xl font-semibold text-center hover:opacity-90 transition-all"
            >
              Request Quote
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-10 md:py-16 bg-neutral-50">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Product Specifications
          </h2>
          <div class="space-y-3">
            {Object.entries(product.specs || {}).map(([key, value]) => (
              <div key={key} class="flex justify-between py-3 border-b border-neutral-100 last:border-0">
                <span class="text-neutral-500 text-sm md:text-base">{key}</span>
                <span class="font-medium text-neutral-900 text-sm md:text-base">{value}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
            Key Features
          </h2>
          <ul class="space-y-3">
            {(product.features || []).map((feature, idx) => (
              <li key={idx} class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-neutral-700 text-sm md:text-base">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-10 md:py-16 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid lg:grid-cols-2 gap-8">
        <div>
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            OEM/ODM Customization Options
          </h2>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-6 border border-blue-100">
            <div class="grid gap-4">
              {Object.entries(product.custom_options || product.customOptions || {}).map(([key, value]) => (
                <div key={key} class="flex items-center gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="font-medium text-neutral-900 text-sm md:text-base">{key}:</span>
                  <span class="text-neutral-600 text-sm md:text-base">{value}</span>
                </div>
              ))}
            </div>
            <a 
              href="/oem-odm" 
              class="mt-6 inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 font-medium"
            >
              Learn more about OEM/ODM services
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <div>
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            Certifications & Testing
          </h2>
          <div class="grid grid-cols-2 gap-3 mb-6">
            {(product.certifications || []).map(cert => (
              <div key={cert} class="bg-green-50 rounded-xl p-4 border border-green-200 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="font-semibold text-green-800 text-sm">{cert}</span>
              </div>
            ))}
          </div>
          {(product.test_report_number) && (
            <div class="bg-neutral-50 rounded-xl p-4">
              <p class="text-sm text-neutral-600">
                <span class="font-medium">Test Report Number:</span> 
                <span class="font-mono ml-2">{product.test_report_number}</span>
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {((product.applications || []).length > 0) && (
    <section class="py-10 md:py-16 bg-neutral-50">
      <div class="container mx-auto px-4 md:px-6">
        <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6 text-center">Application Scenarios</h2>
        <div class="grid md:grid-cols-4 gap-4">
          {(product.applications || []).map((app, idx) => (
            <div key={idx} class="bg-white rounded-xl p-4 text-center shadow-sm hover:shadow-md transition-shadow">
              <span class="text-neutral-700 font-medium text-sm md:text-base">{app}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {relatedProducts.length > 0 && (
    <section class="py-10 md:py-16 bg-white">
      <div class="container mx-auto px-4 md:px-6">
        <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-8">Related Products</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedProducts.map(p => (
            <a href={`/products/${p.slug}`} class="group" key={p.id}>
              <div class="bg-neutral-50 rounded-2xl overflow-hidden transition-all group-hover:shadow-xl">
                <div class="h-44 overflow-hidden">
                  <img src={p.image} alt={p.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                </div>
                <div class="p-4">
                  <h3 class="font-semibold text-neutral-900 group-hover:text-blue-600 transition-colors text-sm md:text-base">{p.title}</h3>
                  <p class="text-sm text-neutral-500 mt-1">MOQ: {p.moq} PCS</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-10 md:py-16 bg-neutral-50">
    <div class="container mx-auto px-4 md:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-8 text-center">Business Information</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
            </div>
            <h3 class="font-semibold text-neutral-900">Payment Terms</h3>
          </div>
          <p class="text-neutral-600 text-sm">{product.paymentTerms}</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <h3 class="font-semibold text-neutral-900">Shipping & Trade</h3>
          </div>
          <p class="text-neutral-600 text-sm mb-2">{product.tradeTerms}</p>
          <p class="text-neutral-600 text-sm">Loading Port: {product.loadingPort}</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <h3 class="font-semibold text-neutral-900">Container Load</h3>
          </div>
          <div class="space-y-1 text-sm">
            <p class="text-neutral-600">20' GP: <span class="font-medium text-neutral-900">{product.containerLoad['20GP']}</span> pcs</p>
            <p class="text-neutral-600">40' GP: <span class="font-medium text-neutral-900">{product.containerLoad['40GP']}</span> pcs</p>
            <p class="text-neutral-600">40' HQ: <span class="font-medium text-neutral-900">{product.containerLoad['40HQ']}</span> pcs</p>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-semibold text-neutral-900">QC Process</h3>
          </div>
          <p class="text-neutral-600 text-sm">{product.qcProcess}</p>
        </div>
      </div>
      <div class="mt-8 max-w-2xl mx-auto bg-white rounded-2xl p-6 shadow-sm border border-neutral-200">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-neutral-900">After-sales Policy</h3>
        </div>
        <p class="text-neutral-600">{product.afterSalesPolicy}</p>
      </div>
    </div>
  </section>

  <section class="py-10 md:py-16 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-8 text-center">Frequently Asked Questions</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {product.faq.map((item, idx) => (
          <div key={idx} class="bg-neutral-50 rounded-2xl overflow-hidden border border-neutral-200">
            <details class="group">
              <summary class="flex items-center justify-between p-6 cursor-pointer select-none">
                <span class="font-semibold text-neutral-900">{item.q}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-6 text-neutral-600">{item.a}</div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-10 md:py-16 bg-gradient-primary">
    <div class="container mx-auto px-4 md:px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Ready to Source This Product?</h2>
      <p class="text-blue-100 mb-8 max-w-2xl mx-auto">
        Get a free quotation with detailed pricing, sample availability, and customized solutions for your brand.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href={`/contact?product=${product.slug}`} class="bg-white text-blue-600 px-8 py-4 rounded-xl font-semibold hover:bg-blue-50 transition-all">
          Get Quote Now
        </a>
        <a href="/contact" class="bg-white/10 text-white border-2 border-white px-8 py-4 rounded-xl font-semibold hover:bg-white/20 transition-all">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>