---
import Layout from '@/layouts/Layout.astro';
import { productsData } from '@/lib/product-data';
import { faqs } from '@/lib/faq-data';
import { generateProductGroupSchema } from '@/lib/schema';

const productGroupSchema = generateProductGroupSchema(productsData);
const featuredFaqs = faqs.filter(f => f.category === 'Product').slice(0, 3);
---

<Layout title="Baby Products - B2Bbaby | ASTM/EN Tested Strollers, Safety Gates, High Chairs" description="High-quality, tested baby products including strollers, safety gates, high chairs from China manufacturer. MOQ 50+, 7-day samples, full QC support.">
  <div>
    <script type="application/ld+json" set:html={JSON.stringify(productGroupSchema)} />
    
    <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-10 md:py-16">
      <div class="container mx-auto px-4 md:px-6">
        <div class="text-center">
          <span class="inline-block bg-white/80 backdrop-blur-sm px-4 py-1 rounded-full text-sm font-medium text-blue-700 mb-4">
            Our Products
          </span>
          <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4">Baby Products</h1>
          <p class="text-base md:text-lg text-neutral-600 max-w-2xl mx-auto">
            High-quality, tested baby products from a professional Chinese manufacturer. 
            Each product undergoes rigorous quality control to ensure safety and compliance.
          </p>
        </div>
      </div>
    </section>

    <section class="py-12 md:py-20 bg-white">
      <div class="container mx-auto px-4 md:px-6">
        <div class="grid md:grid-cols-3 gap-6 md:gap-8 max-w-6xl mx-auto">
          {productsData.map((product, idx) => (
            <article 
              key={product.id} 
              class="bg-white border border-neutral-200 rounded-2xl overflow-hidden hover-lift card-shadow animate-fade-in"
              style={{ animationDelay: `${idx * 150}ms` }}
            >
              <div class="relative h-52 overflow-hidden bg-neutral-100 group">
                <img
                  src={product.image}
                  alt={product.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute top-4 left-4 flex gap-2">
                  <span class="bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-neutral-800">
                    MOQ: {product.moq}
                  </span>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>
              <div class="p-6">
                <h2 class="text-xl font-bold text-neutral-900 mb-2">{product.title}</h2>
                <p class="text-neutral-600 text-sm mb-4 line-clamp-2">{product.description}</p>

                <div class="flex items-center justify-between mb-4 text-sm">
                  <div class="flex items-center gap-2">
                    <span class="text-neutral-500">Lead Time:</span>
                    <span class="font-semibold text-neutral-700">{product.leadTimeProduction}</span>
                  </div>
                </div>

                <div class="flex flex-wrap gap-2 mb-4">
                  {product.certifications.map((cert: string, idx: number) => (
                    <span key={idx} class="bg-green-50 text-green-700 text-xs px-2.5 py-1 rounded-full font-medium">
                      {cert}
                    </span>
                  ))}
                </div>

                <a 
                  href={`/products/${product.slug}`} 
                  class="inline-flex items-center gap-2 w-full justify-center bg-blue-600 text-white px-4 py-3 rounded-xl font-semibold hover:bg-blue-700 transition-colors"
                >
                  View Details
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 md:py-20 bg-neutral-50">
      <div class="container mx-auto px-4 md:px-6">
        <article class="max-w-3xl mx-auto">
          <div class="text-center mb-8">
            <span class="inline-block bg-purple-100 text-purple-700 px-4 py-1 rounded-full text-sm font-medium mb-4">
              FAQs
            </span>
            <h2 class="text-2xl md:text-3xl font-bold text-neutral-900">Product Related Questions</h2>
          </div>
          <div class="space-y-4">
            {featuredFaqs.map((faq, idx) => (
              <div 
                key={faq.id} 
                class="bg-white rounded-xl p-6 border border-neutral-200 hover:border-blue-200 hover:shadow-md transition-all animate-slide-up"
                style={{ animationDelay: `${idx * 100}ms` }}
              >
                <h3 class="text-lg font-semibold text-neutral-900 mb-2">{faq.question}</h3>
                <p class="text-neutral-600 text-sm md:text-base">{faq.answer}</p>
              </div>
            ))}
            <div class="text-center mt-6">
              <a href="/faq" class="inline-flex items-center gap-2 text-blue-600 font-semibold hover:text-blue-700">
                View all FAQs
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="bg-gradient-primary py-12 md:py-16">
      <div class="container mx-auto px-4 md:px-6 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Ready to Source Quality Baby Products?</h2>
        <p class="text-blue-100 mb-6 max-w-xl mx-auto">
          Contact us today for a free quote and let our experts help you find the perfect products for your business.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/contact" class="bg-white text-blue-600 px-8 py-4 rounded-xl font-semibold hover:bg-blue-50 transition-all">
            Get a Quote
          </a>
          <a href="/oem-odm" class="bg-white/10 text-white border-2 border-white px-8 py-4 rounded-xl font-semibold hover:bg-white/20 transition-all">
            OEM/ODM Service
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>