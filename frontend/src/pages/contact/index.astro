---
import Layout from '@/layouts/Layout.astro';
import { generateContactPageSchema } from '@/lib/schema';

const contactSchema = generateContactPageSchema();
---

<Layout title="Contact Us - B2Bbaby | Get Free Consultation & Quote" description="Contact BabyGeo Pro for free consultation and quote for baby products sourcing. Fast response within 24 hours.">
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
  
  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-10 md:py-16">
    <div class="container mx-auto px-4 md:px-6">
      <div class="text-center">
        <span class="inline-block bg-white/80 backdrop-blur-sm px-4 py-1 rounded-full text-sm font-medium text-blue-700 mb-4">
          Contact
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4">Contact Us</h1>
        <p class="text-base md:text-lg text-neutral-600 max-w-2xl mx-auto">
          Get in touch for a free consultation and quote. We typically respond within 24 hours.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8 lg:gap-12">
        <article>
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Get in Touch</h2>
          <div class="space-y-6">
            {[
              {
                icon: 'mail',
                title: 'Email',
                value: 'sourcing@babygeopro.com',
                href: 'mailto:sourcing@babygeopro.com',
                color: 'blue'
              },
              {
                icon: 'phone',
                title: 'WhatsApp',
                value: '+86 176 8112 8186',
                href: 'https://wa.me/8617681128186',
                color: 'green'
              },
              {
                icon: 'clock',
                title: 'Response Time',
                value: 'Within 24 hours',
                color: 'purple'
              }
            ].map((item) => (
              <div key={item.title} class="flex items-start gap-4 group">
                <div class={`w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 transition-all group-hover:scale-110 ${
                  item.color === 'blue' ? 'bg-blue-100 text-blue-600' :
                  item.color === 'green' ? 'bg-green-100 text-green-600' :
                  'bg-purple-100 text-purple-600'
                }`}>
                  {item.icon === 'mail' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                      <polyline points="22,6 12,13 2,6"/>
                    </svg>
                  )}
                  {item.icon === 'phone' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                  )}
                  {item.icon === 'clock' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12,6 12,12 16,14"/>
                    </svg>
                  )}
                </div>
                <div>
                  <h3 class="font-semibold text-neutral-900">{item.title}</h3>
                  {item.href ? (
                    <a href={item.href} class="text-neutral-600 hover:text-blue-600 transition-colors">
                      {item.value}
                    </a>
                  ) : (
                    <p class="text-neutral-600">{item.value}</p>
                  )}
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 p-6 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl border border-blue-100">
            <h3 class="font-bold text-lg text-neutral-900 mb-3">Why Contact Us?</h3>
            <ul class="space-y-3">
              {[
                'Free consultation and quote',
                'Sample availability within 7 days',
                'Custom OEM/ODM solutions',
                'Full certification support'
              ].map((item, idx) => (
                <li key={idx} class="flex items-center gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-neutral-700">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-6 flex items-center gap-4">
            <a
              href="https://wa.me/8617681128186"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 bg-green-600 hover:bg-green-500 rounded-full flex items-center justify-center transition-colors"
              aria-label="Contact us on WhatsApp"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/>
                <path d="M9 9a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
                <path d="M13 9a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
                <path d="M17 9a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
              </svg>
            </a>
            <a
              href="https://linkedin.com/company/babygeopro"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 bg-blue-600 hover:bg-blue-500 rounded-full flex items-center justify-center transition-colors"
              aria-label="Follow us on LinkedIn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7 0h3.8v2h.06c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.77 2.65 4.77 6.1V24h-4v-6.2c0-1.48-.03-3.38-2.06-3.38-2.06 0-2.38 1.6-2.38 3.28V24h-4V8z"/>
              </svg>
            </a>
          </div>
        </article>

        <article>
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-6">Send Us a Message</h2>
          <form action="#" method="POST" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-neutral-700 mb-2">
                Your Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                placeholder="Enter your name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">
                Email Address <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                placeholder="Enter your email"
              />
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-neutral-700 mb-2">
                Company
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                placeholder="Enter your company name"
              />
            </div>

            <div>
              <label for="productInterest" class="block text-sm font-medium text-neutral-700 mb-2">
                Product Interest
              </label>
              <select
                id="productInterest"
                name="productInterest"
                class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
              >
                <option value="">Select a product category</option>
                <option value="stroller">Baby Stroller</option>
                <option value="safety-gate">Safety Gate</option>
                <option value="high-chair">High Chair</option>
                <option value="oem-odm">OEM/ODM Custom</option>
                <option value="sourcing">Factory Sourcing</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-neutral-700 mb-2">
                Your Message <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows={5}
                class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none"
                placeholder="Tell us about your requirements, quantity, certifications needed, etc."
              />
            </div>

            <button
              type="submit"
              class="w-full bg-gradient-primary text-white py-4 rounded-xl font-semibold hover:opacity-90 transition-all hover:shadow-lg"
            >
              Send Message
            </button>
          </form>
          <p class="text-center text-sm text-neutral-500 mt-4">
            We respect your privacy. Your information will not be shared with third parties.
          </p>
        </article>
      </div>
    </div>
  </section>
</Layout>