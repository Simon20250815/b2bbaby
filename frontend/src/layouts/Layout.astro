---
import { generateOrganizationSchema } from '@/lib/schema';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'B2Bbaby - Baby Product Manufacturer & Sourcing', description = 'ASTM/EN certified baby stroller, safety gate, high chair manufacturer. MOQ 50+, 7-day samples, full QC support for US/EU brands.' } = Astro.props;

const organizationSchema = generateOrganizationSchema();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  </head>
  <body class="min-h-screen bg-neutral-50 flex flex-col">
    <Navbar />
    <main class="flex-grow"><slot /></main>
    <Footer />
  </body>
</html>
